{% doc %}
  @prompt
    Make a form where user will submit their email and they will get a pdf. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-pdf-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-pdf-form__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-pdf-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-pdf-form__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 {{ block.settings.description_spacing }}px 0;
    line-height: 1.5;
  }

  .ai-pdf-form__form-wrapper-{{ ai_gen_id }} {
    max-width: {{ block.settings.form_max_width }}px;
    margin: 0 auto;
  }

  .ai-pdf-form__field-group-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.field_gap }}px;
    margin-bottom: {{ block.settings.message_spacing }}px;
  }

  .ai-pdf-form__input-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_font_size }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
  }

  .ai-pdf-form__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
  }

  .ai-pdf-form__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border_color }};
  }

  .ai-pdf-form__button-{{ ai_gen_id }} {
    padding: {{ block.settings.input_padding }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    cursor: pointer;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  .ai-pdf-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-pdf-form__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    font-size: {{ block.settings.message_font_size }}px;
    margin: 0;
  }

  .ai-pdf-form__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: {{ block.settings.message_font_size }}px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-pdf-form__container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }

    .ai-pdf-form__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-pdf-form__field-group-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.field_gap | times: 0.7 }}px;
    }

    .ai-pdf-form__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<pdf-download-form-{{ ai_gen_id }}
  class="ai-pdf-form-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-pdf-form__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-pdf-form__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-pdf-form__description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    <div class="ai-pdf-form__form-wrapper-{{ ai_gen_id }}">
      {% form 'contact' %}
        <input
          type="hidden"
          name="contact[pdf_download]"
          value="true"
        >
        <input
          type="hidden"
          name="contact[pdf_title]"
          value="{{ block.settings.pdf_title }}"
        >
        {% if block.settings.pdf_file %}
          <input
            type="hidden"
            name="contact[pdf_url]"
            value="{{ block.settings.pdf_file }}"
          >
        {% endif %}

        <div class="ai-pdf-form__field-group-{{ ai_gen_id }}">
          <input
            type="email"
            name="contact[email]"
            class="ai-pdf-form__input-{{ ai_gen_id }}"
            value="{{ form.email }}"
            placeholder="{{ block.settings.email_placeholder }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-pdf-form-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-pdf-form-success-{{ ai_gen_id }}"
            {% endif %}
            required
          >
          <button
            type="submit"
            class="ai-pdf-form__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </button>
        </div>

        {% if form.errors %}
          <div
            id="ai-pdf-form-error-{{ ai_gen_id }}"
            class="ai-pdf-form__error-{{ ai_gen_id }}"
          >
            {{ form.errors.messages.email }}
          </div>
        {% endif %}

        {% if form.posted_successfully? %}
          <div
            id="ai-pdf-form-success-{{ ai_gen_id }}"
            class="ai-pdf-form__success-{{ ai_gen_id }}"
          >
            {{ block.settings.success_message }}
          </div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</pdf-download-form-{{ ai_gen_id }}>

<script>
  (function() {
    class PdfDownloadForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        const pdfUrl = '{{ block.settings.pdf_file }}';

        if (form && pdfUrl) {
          form.addEventListener('submit', (event) => {
            const emailInput = form.querySelector('input[type="email"]');
            if (emailInput && emailInput.value && emailInput.validity.valid) {
              setTimeout(() => {
                window.open(pdfUrl, '_blank');
              }, 500);
            }
          });
        }
      }
    }

    customElements.define('pdf-download-form-{{ ai_gen_id }}', PdfDownloadForm{{ ai_gen_id }});
  })();
</script>

