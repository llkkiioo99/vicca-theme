
{% schema %}
{
  "name": "Custom Info CTA",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf8f3"
    },
    {
      "type": "textarea",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "Si te identificas con esta forma de hacer las cosas y quieres recibir toda la información en detalle sin compromiso..."
    },
    {
      "type": "text",
      "id": "btn_left_text",
      "label": "Button Text",
      "default": "Quiero recibir la info"
    },
    {
      "type": "url",
      "id": "btn_left_link",
      "label": "Button Link (fallback)"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button Color",
      "default": "#ff9e5e"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Custom Info CTA"
    }
  ]
}
{% endschema %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');

  .custom-cta-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 20px;
    padding-right: 20px;
    font-family: 'Poppins', sans-serif;
  }

  .cta-container-{{ section.id }} {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }

  .cta-content-{{ section.id }} {
    max-width: 600px;
    position: relative;
  }

  .cta-heading-{{ section.id }} {
    font-family: 'Poppins', sans-serif;
    font-size: 22px;
    font-weight: 500;
    line-height: 1.3;
    color: #000;
    margin-bottom: 36px;
    margin-top: 0;
  }

  .button-group-{{ section.id }} {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-top: 20px;
  }

  .pill-nav-{{ section.id }} {
    display: inline-flex;
    border: 2px solid #000;
    border-radius: 50px;
    overflow: hidden;
  }

  .pill-nav-{{ section.id }} a {
    text-decoration: none;
    padding: 12px 28px;
    font-size: 15px;
    font-weight: 600;
    color: #000;
    transition: 0.3s;
    text-align: center;
    font-family: 'Poppins', sans-serif;
    background-color: {{ section.settings.accent_color }};
    cursor: pointer;
  }

  .pill-nav-{{ section.id }} a:hover { filter: brightness(0.9); }

  .sub-text-{{ section.id }} {
    text-align: right;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    margin-top: 12px;
    color: #333;
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .cta-heading-{{ section.id }} { font-size: 20px; text-align: center; }
    .button-group-{{ section.id }} { justify-content: center; }
    .pill-nav-{{ section.id }} { width: 100%; }
    .pill-nav-{{ section.id }} a { width: 100%; padding: 14px 20px; }
    .sub-text-{{ section.id }} { text-align: center; }
  }
</style>

<section class="custom-cta-{{ section.id }}">
  <div class="cta-container-{{ section.id }}">
    <div class="cta-content-{{ section.id }}">
      <h2 class="cta-heading-{{ section.id }}">{{ section.settings.heading_text }}</h2>
    </div>

    <div class="button-group-{{ section.id }}">
      <div class="pill-wrapper">
        <div class="pill-nav-{{ section.id }}">
          <a href="javascript:void(0)" onclick="viccaOpenSignupModal()">{{ section.settings.btn_left_text }}</a>
        </div>
        <p class="sub-text-{{ section.id }}">Desliza para saber más...</p>
      </div>
    </div>
  </div>
</section>