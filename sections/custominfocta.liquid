
{% schema %}
{
  "name": "Custom Info CTA",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf8f3"
    },
    {
      "type": "textarea",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "Si te identificas con esta forma de hacer las cosas y quieres recibir toda la información en detalle sin compromiso..."
    },
    {
      "type": "text",
      "id": "btn_left_text",
      "label": "Button Text",
      "default": "Quiero recibir la info"
    },
    {
      "type": "url",
      "id": "btn_left_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button Color",
      "default": "#ff9e5e"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Custom Info CTA"
    }
  ]
}
{% endschema %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');

  .custom-cta-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 20px;
    padding-right: 20px;
    font-family: 'Poppins', sans-serif;
  }

  .cta-container {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }

  .cta-content {
    max-width: 600px;
    position: relative;
  }

  .cta-heading {
    font-family: 'Poppins', sans-serif;
    font-size: 24px;
    font-weight: 500;
    line-height: 1.2;
    color: #000;
    margin-bottom: 40px;
    margin-top: 0;
  }

  .stars-icon {
    position: absolute;
    top: -10px;
    right: -60px;
    width: 60px;
  }

  .button-group {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-top: 20px;
  }

  .pill-nav {
    display: inline-flex;
    border: 2px solid #000;
    border-radius: 50px; /* Mantiene la forma redondeada */
    overflow: hidden;
  }

  .pill-nav a {
    text-decoration: none;
    padding: 12px 25px;
    font-size: 16px;
    font-weight: 600;
    color: #000;
    transition: 0.3s;
    text-align: center;
    font-family: 'Poppins', sans-serif;
    background-color: {{ section.settings.accent_color }}; /* Ahora el botón principal usa el color de acento */
  }

  .pill-nav a:hover {
    filter: brightness(0.9);
  }

  .sub-text {
    text-align: right;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    margin-top: 15px;
    color: #333;
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .cta-heading { 
      font-size: 22px; 
      text-align: center; 
    }
    .stars-icon { display: none; }
    .button-group { justify-content: center; }
    .pill-nav { 
      width: 100%; 
    }
    .pill-nav a {
      width: 100%;
    }
    .sub-text { text-align: center; }
  }
</style>

<section class="custom-cta-{{ section.id }}">
  <div class="cta-container">
    <div class="cta-content">
      <h2 class="cta-heading">{{ section.settings.heading_text }}</h2>
      <div class="stars-icon">
        <svg viewBox="0 0 24 24" fill="black" width="40">
          <path d="M12 2L14.5 9H22L16 14L18.5 21L12 17L5.5 21L8 14L2 9H9.5L12 2Z"/>
        </svg>
      </div>
    </div>

    <div class="button-group">
      <div class="pill-wrapper">
        <div class="pill-nav">
          <a href="{{ section.settings.btn_left_link }}">{{ section.settings.btn_left_text }}</a>
        </div>
        <p class="sub-text">Desliza para saber más...</p>
      </div>
    </div>
  </div>
</section>