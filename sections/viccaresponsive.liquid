{%- style -%}
  .custom-hero-{{ section.id }} {
    width: 100%;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    padding: 60px 20px;
  
    background-image: url('{{ section.settings.image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: scroll;
  }

  .hero-content-{{ section.id }} {
    max-width: 800px;
    z-index: 2;
  }

  .hero-content-{{ section.id }} h2 {
    font-size: clamp(2rem, 5vw, 4rem); 
    margin-bottom: 20px;
    color: {{ section.settings.text_color }};
  }

  .hero-content-{{ section.id }} p {
    font-size: 1.2rem;
    margin-bottom: 30px;
    color: {{ section.settings.text_color }};
  }

  .hero-btn-{{ section.id }} {
    display: inline-block;
    padding: 15px 35px;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    text-decoration: none;
    border-radius: 4px;
    font-weight: bold;
    transition: 0.3s ease;
  }

  .hero-btn-{{ section.id }}:hover {
    opacity: 0.8;
  }

 
  @media screen and (max-width: 768px) {
    .custom-hero-{{ section.id }} {
      min-height: 60vh;
      background-position: left center; 
    }
  }
{%- endstyle -%}

<section class="custom-hero-{{ section.id }}">
  <div class="hero-content-{{ section.id }}">
    {% if section.settings.title != blank %}
      <h2>{{ section.settings.title }}</h2>
    {% endif %}
    
    {% if section.settings.subtext != blank %}
      <p>{{ section.settings.subtext }}</p>
    {% endif %}

    {% if section.settings.btn_label != blank %}
      <a href="{{ section.settings.btn_link }}" class="hero-btn-{{ section.id }}">
        {{ section.settings.btn_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Custom BG Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Your Hero Title Here"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Write something catchy about your brand."
    },
    {
        "type": "color",
        "id": "text_color",
        "label": "Text Color",
        "default": "#333333"
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Custom BG Hero"
    }
  ]
}
{% endschema %}