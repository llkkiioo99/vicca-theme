{%- style -%}
  /* Variables de Espaciado dinámico */
  #shopify-section-{{ section.id }} .vicca-affiliate-wrapper {
    background-color: {{ section.settings.bg_color }};
    background-image: url('{{ section.settings.bg_image | image_url: width: 1500 }}');
    background-repeat: no-repeat;
    background-position: left bottom;
    background-size: contain;
    
    /* Desktop Padding */
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: 20px;
    padding-right: 20px;
    
    display: flex;
    align-items: center;
    min-height: 400px;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .vicca-container-{{ section.id }} {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    z-index: 2;
  }

  .vicca-title-{{ section.id }} {
    font-size: clamp(24px, 3.5vw, 34px);
    font-weight: 800;
    margin-bottom: 24px;
    color: {{ section.settings.text_color }};
    font-family: inherit;
    line-height: 1.2;
  }

  .vicca-title-{{ section.id }} span {
    color: {{ section.settings.dot_color }};
  }

  .vicca-content-{{ section.id }} p {
    font-size: clamp(14px, 1.5vw, 17px);
    line-height: 1.6;
    margin-bottom: 18px;
    max-width: 700px;
    color: {{ section.settings.text_color }};
    font-family: inherit;
  }

  /* Responsividad para Tablet y Móvil */
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .vicca-affiliate-wrapper {
      background-size: 50%; /* Imagen más pequeña en móvil para no tapar texto */
      background-position: bottom left;
      
      /* Mobile Padding */
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      padding-left: 15px;
      padding-right: 15px;
      min-height: auto;
    }
    
    .vicca-title-{{ section.id }} {
      text-align: left;
      margin-bottom: 16px;
    }
  }

  @media screen and (max-width: 480px) {
    #shopify-section-{{ section.id }} .vicca-affiliate-wrapper {
      min-height: auto;
      background-size: 40%;
      padding-left: 16px;
      padding-right: 16px;
    }
    .vicca-content-{{ section.id }} p { font-size: 14px; }
  }
{%- endstyle -%}

<section class="vicca-affiliate-wrapper">
  <div class="vicca-container-{{ section.id }}">
    
    <h2 class="vicca-title-{{ section.id }}">
      {{ section.settings.title | replace: '.', '<span>.</span>' }}
    </h2>
    
    <div class="vicca-content-{{ section.id }}">
      {{ section.settings.content_html }}
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Vicca Affiliate",
  "settings": [
    {
      "type": "header",
      "content": "Diseño y Colores"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Imagen de Fondo (Nodos)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#fdfaf5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del Texto",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Color del punto decorativo",
      "default": "#f39c12"
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Ser un vicca.afiliate es..."
    },
    {
      "type": "richtext",
      "id": "content_html",
      "label": "Contenido",
      "default": "<p>Recomendar un programa que sí acompaña de verdad a las personas que quieren mudarse a Holanda.</p>"
    },
    {
      "type": "header",
      "content": "Espaciado (Padding) - Escritorio"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Inferior (Desktop)",
      "default": 80
    },
    {
      "type": "header",
      "content": "Espaciado (Padding) - Móvil"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior (Móvil)",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Inferior (Móvil)",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Vicca Affiliate Section"
    }
  ]
}
{% endschema %}