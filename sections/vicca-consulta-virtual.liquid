{% schema %}
{
  "name": "Consulta Virtual Cal",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Consulta Virtual"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Habla directamente con nuestro equipo."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Reserva una videollamada gratuita con el equipo de VICCA. Te explicaremos todo sobre el programa, resolveremos tus dudas y crearemos un plan personalizado para ti."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf9f3"
    }
  ],
  "presets": [
    {
      "name": "Consulta Virtual Cal"
    }
  ]
}
{% endschema %}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<section class="vcv-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="vcv-container">

    <div class="vcv-header">
      <h1 class="vcv-title">{{ section.settings.heading }}<span class="vcv-dot">.</span></h1>
      <p class="vcv-sub">{{ section.settings.subheading }}</p>
      <p class="vcv-desc">{{ section.settings.description }}</p>
    </div>

    <div class="vcv-features">
      <div class="vcv-feature">
        <span class="vcv-feat-icon">📹</span>
        <span class="vcv-feat-text">Vía Google Meet</span>
      </div>
      <div class="vcv-feature">
        <span class="vcv-feat-icon">⏱</span>
        <span class="vcv-feat-text">45 minutos</span>
      </div>
      <div class="vcv-feature">
        <span class="vcv-feat-icon">✓</span>
        <span class="vcv-feat-text">Sin compromiso</span>
      </div>
    </div>

    <div class="vcv-cal-card">
      <div class="vcv-cal-embed" id="my-cal-inline-consulta-virtual-con-el-equipo-vicca"></div>
    </div>

  </div>
</section>

<!-- Cal.com embed script -->
<script type="text/javascript">
(function (C, A, L) {
  var p = function (a, ar) { a.q.push(ar); };
  var d = C.document;
  C.Cal = C.Cal || function () {
    var cal = C.Cal;
    var ar = arguments;
    if (!cal.loaded) {
      cal.ns = {};
      cal.q = cal.q || [];
      d.head.appendChild(d.createElement("script")).src = A;
      cal.loaded = true;
    }
    if (ar[0] === L) {
      var api = function () { p(api, arguments); };
      var namespace = ar[1];
      api.q = api.q || [];
      if (typeof namespace === "string") { cal.ns[namespace] = cal.ns[namespace] || api; p(cal.ns[namespace], ar); p(cal, ["initNamespace", namespace]); } else p(cal, ar);
      return;
    }
    p(cal, ar);
  };
})(window, "https://app.cal.eu/embed/embed.js", "init");

Cal("init", "consulta-virtual-con-el-equipo-vicca", { origin: "https://app.cal.eu" });

Cal.ns["consulta-virtual-con-el-equipo-vicca"]("inline", {
  elementOrSelector: "#my-cal-inline-consulta-virtual-con-el-equipo-vicca",
  config: { "layout": "month_view", "theme": "light" },
  calLink: "viccaagency/consulta-virtual-con-el-equipo-vicca"
});

Cal.ns["consulta-virtual-con-el-equipo-vicca"]("ui", {
  "theme": "light",
  "hideEventTypeDetails": true,
  "layout": "month_view",
  "cssVarsPerTheme": {
    "light": {
      "cal-bg": "255,255,255",
      "cal-text": "0,0,0",
      "cal-text-emphasis": "0,0,0",
      "cal-border-emphasis": "224,224,224",
      "cal-text-default": "51,51,51",
      "cal-border-default": "224,224,224",
      "cal-border-subtle": "240,240,240",
      "cal-bg-emphasis": "245,245,245",
      "cal-bg-subtle": "250,250,250",
      "cal-bg-muted": "255,255,255",
      "cal-brand": "255,145,77"
    }
  },
  styles: { branding: { brandColor: "#ff914d" } }
});
</script>

<style>
  .vcv-section {
    padding: 100px 20px 120px;
    font-family: 'Poppins', sans-serif;
  }

  .vcv-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .vcv-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .vcv-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 900;
    color: #000;
    margin: 0 0 12px 0;
    line-height: 1.15;
  }

  .vcv-dot { color: #ff914d; }

  .vcv-sub {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(16px, 1.8vw, 20px);
    font-weight: 600;
    color: #333;
    margin: 0 0 20px 0;
  }

  .vcv-desc {
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    color: #666;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Feature pills */
  .vcv-features {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .vcv-feature {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    border: 1.5px solid #e8e4df;
    border-radius: 50px;
    padding: 12px 24px;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #333;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .vcv-feat-icon {
    font-size: 16px;
  }

  /* Cal card */
  .vcv-cal-card {
    background: #ffffff;
    border-radius: 30px;
    padding: 32px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.06);
    min-height: 680px;
  }

  .vcv-cal-embed {
    min-height: 600px;
    border-radius: 20px;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .vcv-section { padding: 70px 16px 80px; }
    .vcv-cal-card { padding: 20px 16px; border-radius: 24px; min-height: 500px; }
    .vcv-cal-embed { min-height: 450px; }
    .vcv-features { gap: 10px; }
    .vcv-feature { padding: 10px 18px; font-size: 13px; }
  }

  @media (max-width: 480px) {
    .vcv-section { padding: 50px 12px 60px; }
    .vcv-cal-card { padding: 16px 12px; border-radius: 20px; }
    .vcv-features { flex-direction: column; align-items: center; }
  }
</style>
