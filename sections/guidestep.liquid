{%- style -%}
  /* Fonts Import */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:wght@300;400;600;700;900&display=swap');

  .hero-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    font-family: 'Poppins', sans-serif;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .serif-{{ section.id }} {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    letter-spacing: -1px;
  }

  /* Responsive Title sizing */
  .hero-title-{{ section.id }} {
    font-size: clamp(3rem, 10vw, 3.5rem); /* Dynamically scales between 3rem and 5.5rem */
    line-height: 0.95;
  }

  .btn-{{ section.id }} {
    background-color: {{ section.settings.accent_color }};
    color: #ffffff;
    text-align: center;
    font-family: 'Poppins', sans-serif;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
  }
  
  .btn-{{ section.id }}:hover {
    background-color: #000000 !important;
    color: {{ section.settings.accent_color }} !important;
  }

  /* Image container - Optimized for all screens */
  .image-container-{{ section.id }} {
    background-color: #ffffff;
    border-radius: clamp(30px, 5vw, 60px);
    padding: clamp(1.5rem, 5vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 500px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    position: relative;
    box-shadow: 0 15px 45px rgba(0,0,0,0.04);
  }

  /* Book Wrapper and 3D Effect */
  .book-wrapper-{{ section.id }} {
    position: relative;
    width: 65%; 
    perspective: 1500px;
    z-index: 10;
  }

  .book-image-{{ section.id }} {
    width: 100%;
    height: auto;
    transform: rotateY(-25deg) rotateX(5deg) rotateZ(1deg);
    transform-style: preserve-3d;
    filter: drop-shadow(15px 20px 25px rgba(0,0,0,0.18));
  }

  /* Static shadow under the book */
  .book-wrapper-{{ section.id }}::after {
    content: "";
    position: absolute;
    bottom: -30px;
    left: 10%;
    width: 80%;
    height: 20px;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 50%;
    filter: blur(15px);
    z-index: -1;
    transform: rotateX(70deg);
  }

  /* Media Queries for fine-tuning */
  @media (max-width: 768px) {
    .hero-{{ section.id }} {
      padding: 4rem 1.5rem;
    }
    .hero-title-{{ section.id }} {
      margin-bottom: 1.5rem;
    }
    .image-container-{{ section.id }} {
      max-width: 320px; /* Smaller container for mobile */
    }
  }

  @media (min-width: 1024px) {
    .hero-{{ section.id }} {
      min-height: 85vh; /* Laptop height */
    }
  }
{%- endstyle -%}

<script src="https://cdn.tailwindcss.com"></script>

<section class="hero-{{ section.id }} relative py-12 md:py-20">
  <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-12 lg:gap-16">
      
      <div class="w-full md:w-1/2 text-center md:text-left order-2 md:order-1">
        <h2 class="hero-title-{{ section.id }} font-bold text-black">
          <span class="serif-{{ section.id }} block">{{ section.settings.title_1 }}</span>
          <span class="font-black block" style="font-family: 'Poppins', sans-serif;">{{ section.settings.title_2 }}</span>
        </h2>
        
        <p class="mt-6 text-gray-700 text-base md:text-lg lg:text-xl max-w-md mx-auto md:mx-0 leading-relaxed font-normal">
          {{ section.settings.description }}
        </p>
        
        <div class="mt-10 md:mt-12">
          <a href="{{ section.settings.button_link }}" class="btn-{{ section.id }} inline-block font-bold py-4 md:py-5 px-10 md:px-14 rounded-full text-lg w-full md:w-auto">
            {{ section.settings.button_label }}
          </a>
        </div>
      </div>

      <div class="w-full md:w-1/2 flex justify-center order-1 md:order-2">
        <div class="image-container-{{ section.id }}">
          <div class="book-wrapper-{{ section.id }}">
            {% if section.settings.image != blank %}
              <img src="{{ section.settings.image | img_url: '800x' }}" 
                   alt="{{ section.settings.image.alt }}" 
                   loading="lazy"
                   class="book-image-{{ section.id }}">
            {% else %}
              <img src="https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-product-1_large.png" 
                   class="book-image-{{ section.id }} opacity-30">
            {% endif %}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Step Into Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF7F2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Button Color",
      "default": "#FF9E67"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Heading Part 1 (Serif)",
      "default": "Step Into"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Heading Part 2 (Poppins Bold)",
      "default": "Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Cómo la guía digital puede ayudarte a mudarte a los Países Bajos."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Consigue tu guía aquí"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Book Image"
    }
  ],
  "presets": [
    {
      "name": "Step Into Hero"
    }
  ]
}
{% endschema %}