{% comment %}
  Vicca Affiliate Requirements Section - Redesigned
{% endcomment %}

<div class="affr-section-{{ section.id }}">
  <div class="affr-container">
    <div class="affr-card">
      <p class="affr-label">Requisitos</p>
      <h2 class="affr-heading">
        {{ section.settings.title }}<span class="affr-dot">.</span>{{ section.settings.subtitle }}
      </h2>
      <p class="affr-subtitle">{{ section.settings.headline }}</p>
      <p class="affr-intro">{{ section.settings.intro_text }}</p>

      <div class="affr-list">
        {{ section.settings.list_items }}
      </div>

      <p class="affr-footer">{{ section.settings.footer_text }}</p>
    </div>
  </div>
</div>

{% style %}
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');

.affr-section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background-color: {{ section.settings.bg_color }};
  font-family: 'Poppins', sans-serif;
}

.affr-container {
  max-width: 680px;
  margin: 0 auto;
  padding: 0 20px;
}

.affr-card {
  background: #111;
  border-radius: 32px;
  padding: 48px 44px;
  box-shadow: 0 6px 30px rgba(0,0,0,0.08);
  color: #fff;
}

.affr-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: #ff914d;
  margin: 0 0 16px;
}

.affr-heading {
  font-family: 'Poppins', sans-serif;
  font-size: clamp(24px, 3vw, 30px);
  font-weight: 800;
  color: #fff;
  margin: 0 0 10px;
  letter-spacing: -0.5px;
  line-height: 1.2;
}

.affr-dot { color: #ff914d; font-weight: 900; }

.affr-subtitle {
  font-size: 16px;
  font-weight: 700;
  color: rgba(255,255,255,0.9);
  margin: 0 0 6px;
}

.affr-intro {
  font-size: 15px;
  font-weight: 400;
  color: rgba(255,255,255,0.6);
  margin: 0 0 28px;
  line-height: 1.5;
}

.affr-list {
  margin: 0 0 28px;
}

.affr-list ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.affr-list li {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 12px 0;
  font-size: 15px;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.affr-list li:last-child { border-bottom: none; }

.affr-list li::before {
  content: '\2713';
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: #ff914d;
  color: #111;
  font-size: 12px;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 1px;
}

.affr-footer {
  font-size: 16px;
  font-weight: 700;
  color: #ff914d;
  text-align: center;
  margin: 0;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.08);
}

@media (max-width: 768px) {
  .affr-card { padding: 36px 28px; border-radius: 24px; }
  .affr-heading { font-size: 24px; }
}

@media (max-width: 480px) {
  .affr-card { padding: 28px 22px; border-radius: 20px; }
  .affr-heading { font-size: 22px; }
  .affr-list li { font-size: 14px; padding: 10px 0; }
  .affr-intro { font-size: 14px; }
  .affr-footer { font-size: 15px; }
  .affr-container { padding: 0 16px; }
}
{% endstyle %}

{% schema %}
{
  "name": "Vicca Affiliate Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f6f0"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title Part 1",
      "default": "Requisitos para ser vicca"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Title Part 2",
      "default": "afiliate"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Sub-headline (Bold)",
      "default": "No pedimos números, pedimos actitud."
    },
    {
      "type": "text",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "Para formar parte del programa necesitas:"
    },
    {
      "type": "richtext",
      "id": "list_items",
      "label": "List Items",
      "default": "<ul><li>Tener una comunicación honesta y clara</li><li>Recomendar solo a personas que realmente puedan encajar en el programa</li><li>Respetar el proceso y las normas del programa</li><li>Valorar el trato cercano y humano tanto como el profesional</li></ul>"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Bottom Bold Text",
      "default": "Si esto te suena lógico, probablemente encajes."
    }
  ],
  "presets": [
    {
      "name": "Vicca Affiliate Section"
    }
  ]
}
{% endschema %}
