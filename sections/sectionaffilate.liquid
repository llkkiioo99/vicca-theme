{% comment %}
  Vicca Affiliate Requirements Section - EXACT MATCH
{% endcomment %}

<div class="vicca-section-wrapper-{{ section.id }}">
  <div class="vicca-container">
    
    <h2 class="vicca-title">
      {{ section.settings.title }}<span class="orange-dot">.</span>{{ section.settings.subtitle }}
    </h2>

    <p class="vicca-headline"><strong>{{ section.settings.headline }}</strong></p>

    <div class="vicca-alignment-box">
      <p class="vicca-intro">{{ section.settings.intro_text }}</p>
      
      <div class="vicca-list-container">
        {{ section.settings.list_items }}
      </div>
    </div>

    <p class="vicca-footer-text"><strong>{{ section.settings.footer_text }}</strong></p>

  </div>
</div>

{% style %}
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap');

.vicca-section-wrapper-{{ section.id }} {
  background-color: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  text-align: center;
  font-family: 'Poppins', sans-serif;
  color: #000;
  line-height: 1.4;
}

.vicca-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

.vicca-title {
  font-family: 'Poppins', sans-serif !important;
  font-size: clamp(24px, 3vw, 30px);
  font-weight: 600;
  margin: 0 auto 28px auto;
  letter-spacing: -1px;
  display: block;
  text-align: center;
}

.orange-dot {
  color: #ff6b00;
}

.vicca-headline {
  font-family: 'Poppins', sans-serif;
  font-size: 1.1rem;
  margin-bottom: 32px;
  text-align: center;
}

/* Container that holds the intro and list - Left aligned but centered as a block */
.vicca-alignment-box {
  display: inline-block;
  text-align: left;
  width: 100%;
  max-width: 680px; /* Controls the 'left' shift of the description */
  margin: 0 auto;
}

.vicca-intro {
  margin-bottom: 20px;
  font-size: 1rem;
}

.vicca-list-container {
  font-size: 1rem;
}

.vicca-list-container ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.vicca-list-container li {
  margin-bottom: 6px;
}

.vicca-footer-text {
  margin-top: 36px;
  font-size: 1.1rem;
  text-align: center;
}

@media (max-width: 768px) {
  .vicca-title { font-size: 24px; }
  .vicca-headline { font-size: 1rem; }
  .vicca-alignment-box { max-width: 100%; text-align: left; }
  .vicca-footer-text { font-size: 1rem; }
  .vicca-section-wrapper-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | divided_by: 2 }}px;
    padding-bottom: {{ section.settings.padding_bottom | divided_by: 2 }}px;
  }
}

@media (max-width: 480px) {
  .vicca-title { font-size: 22px; letter-spacing: -0.5px; }
  .vicca-headline { font-size: 15px; margin-bottom: 24px; }
  .vicca-intro { font-size: 14px; }
  .vicca-list-container { font-size: 14px; }
  .vicca-footer-text { font-size: 15px; margin-top: 28px; }
  .vicca-container { padding: 0 16px; }
}
{% endstyle %}

{% schema %}
{
  "name": "Vicca Affiliate Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f6f0"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title Part 1",
      "default": "Requisitos para ser vicca"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Title Part 2",
      "default": "afiliate"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Sub-headline (Bold)",
      "default": "No pedimos números, pedimos actitud."
    },
    {
      "type": "text",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "Para formar parte del programa necesitas:"
    },
    {
      "type": "richtext",
      "id": "list_items",
      "label": "List Items",
      "default": "<ul><li>Tener una comunicación honesta y clara</li><li>Recomendar solo a personas que realmente puedan encajar en el programa</li><li>Respetar el proceso y las normas del programa</li><li>Valorar el trato cercano y humano tanto como el profesional</li></ul>"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Bottom Bold Text",
      "default": "Si esto te suena lógico, probablemente encajes."
    }
  ],
  "presets": [
    {
      "name": "Vicca Affiliate Section"
    }
  ]
}
{% endschema %}