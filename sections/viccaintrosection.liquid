{% style %}
  /* Importación de Poppins */
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

  /* Aplicación global */
  #vicca-section-{{ section.id }}, 
  #vicca-section-{{ section.id }} * {
    font-family: 'Poppins', sans-serif !important;
    box-sizing: border-box;
  }

  #vicca-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    color: #000000;
    overflow: hidden;
  }

  .vicca-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Headline Styles */
  .vicca-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .vicca-header h2 {
    font-size: clamp(24px, 4vw, 36px); /* Tamaño fluido según pantalla */
    font-weight: 500; 
    line-height: 1.2;
    letter-spacing: -0.5px;
    margin: 0;
  }

  .vicca-brand { font-weight: 700; color: #000; }
  .vicca-dot { color: #f38a4e; }
  .vicca-highlight { color: #f38a4e; font-weight: 600; }

  /* Layout Grid Responsivo */
  .vicca-content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr; /* 2 columnas en Desktop */
    align-items: center;
    gap: 40px;
  }

  .vicca-image-wrapper {
    width: 100%;
  }

  .vicca-image-wrapper img, 
  .vicca-image-wrapper svg {
    width: 100%;
    height: auto;
    max-height: 450px; /* Evita que crezca demasiado en pantallas gigantes */
    object-fit: cover;
    display: block;
    border-radius: 30px; 
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .vicca-text-wrapper {
    width: 100%;
  }

  .vicca-body-text, 
  .vicca-body-text p {
    font-size: 17px;
    line-height: 1.8;
    font-weight: 400;
    color: #333;
    margin-bottom: 20px;
  }

  .vicca-body-text strong {
    font-weight: 700;
    color: #000;
  }

  /* --- RESPONSIVIDAD --- */

  /* Laptops y Pantallas Medianas (max 1024px) */
  @media (max-width: 1024px) {
    .vicca-container { padding: 0 40px; }
    .vicca-content-grid { gap: 30px; }
    .vicca-body-text { font-size: 16px; }
  }

  /* Tablets (max 768px) */
  @media (max-width: 768px) {
    #vicca-section-{{ section.id }} {
      padding-top: 50px;
      padding-bottom: 50px;
    }
    .vicca-content-grid {
      grid-template-columns: 1fr; /* Una sola columna */
      text-align: center;
      gap: 30px;
    }
    .vicca-header { margin-bottom: 40px; }
    .vicca-image-wrapper { order: -1; } /* Imagen siempre arriba en móvil */
    .vicca-body-text, .vicca-body-text p {
      text-align: center;
    }
  }

  /* Smartphones (max 480px) */
  @media (max-width: 480px) {
    .vicca-container { padding: 0 20px; }
    .vicca-header h2 { font-size: 24px; }
    .vicca-image-wrapper img { border-radius: 20px; }
    .vicca-body-text { font-size: 15px; }
  }
{% endstyle %}

<section id="vicca-section-{{ section.id }}">
  <div class="vicca-container">
    <div class="vicca-header">
      <h2>
        En <span class="vicca-brand">vicca<span class="vicca-dot">.</span></span> ponemos a tu disposición<br>
        nuestro <span class="vicca-highlight">único programa de acompañamiento.</span>
      </h2>
    </div>

    <div class="vicca-content-grid">
      <div class="vicca-image-wrapper">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.image.alt }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      <div class="vicca-text-wrapper">
        <div class="vicca-body-text">
          {{ section.settings.content_text }}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vicca Intro Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfbf8"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "richtext",
      "id": "content_text",
      "label": "Body Text",
      "default": "<p>Nuestro <strong>objetivo</strong> es facilitar tu mudanza y adaptación a los Países Bajos, combinando la gestión práctica de trámites y procesos con un apoyo cercano y humano. No tendrás que hacerlo todo solo/a: te ayudamos a resolver gestiones, entender cada paso con claridad y avanzar de forma fácil y rápida, aumentando tus posibilidades de encontrar trabajo y vivienda en menos tiempo y con menos estrés.</p>"
    }
  ],
  "presets": [
    {
      "name": "Vicca Intro Section"
    }
  ]
}
{% endschema %}