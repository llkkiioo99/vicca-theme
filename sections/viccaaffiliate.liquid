{% schema %}
{
  "name": "Affiliate Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF7F0"
    },
    {
      "type": "header",
      "content": "Botón Izquierdo (Naranja)"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Texto",
      "default": "Quiero afiliarme"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Enlace (fallback)"
    },
    {
      "type": "header",
      "content": "Botón Derecho (Negro)"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Texto",
      "default": "Ya soy vicca.afiliate"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Enlace (fallback)"
    }
  ],
  "presets": [
    {
      "name": "Affiliate Banner"
    }
  ]
}
{% endschema %}

<div class="vicca-banner-wrapper" style="background-color: {{ section.settings.bg_color }};">
  <div class="vicca-aff-container">
    <div class="vicca-content-grid">

      <div class="vicca-title-area">
        <h2 class="vicca-main-title">
          <span class="serif-font">Programa de</span>
          <span class="bold-font">afiliados</span>
        </h2>
      </div>

      <div class="vicca-text-area">
        <p class="vicca-description">
          Conviértete en un <strong>vicca<span class="dot-orange">.</span>afiliate </strong> y ayuda a personas a empezar una nueva vida en Holanda con nuestro programa <span class="highlight-text">ganando dinero por ello.</span>
        </p>
      </div>

    </div>

    <div class="vicca-button-container">
      <div class="vicca-button-group">
        {%- if section.settings.button_1_text != blank -%}
          <a href="javascript:void(0)" class="btn-orange" onclick="viccaOpenSignupModal()">
            {{ section.settings.button_1_text }}
          </a>
        {%- endif -%}

        {%- if section.settings.button_2_text != blank -%}
          <a href="javascript:void(0)" class="btn-black" onclick="viccaOpenAffiliateModal()">
            {{ section.settings.button_2_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400&family=Poppins:wght@400;700;800;900&display=swap');

  .vicca-banner-wrapper {
    padding: 80px 5%;
    font-family: 'Poppins', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .vicca-aff-container {
    max-width: 1100px;
    width: 100%;
  }

  .vicca-content-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 50px;
    align-items: center;
    margin-bottom: 60px;
  }

  .vicca-main-title {
    margin: 0;
    line-height: 0.85;
    color: #000;
  }

  .vicca-main-title .serif-font {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 5vw, 52px);
    display: block;
    font-weight: 400;
    margin-bottom: 10px;
  }

  .vicca-main-title .bold-font {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(48px, 7vw, 80px);
    font-weight: 900;
    display: block;
    letter-spacing: -2px;
    text-transform: lowercase;
  }

  .vicca-description {
    font-size: clamp(18px, 2.5vw, 24px);
    line-height: 1.4;
    color: #000;
    margin: 0;
    font-weight: 400;
  }

  .vicca-description strong { font-weight: 800; }
  .dot-orange { color: #FF914D; font-weight: 900; }

  .highlight-text {
    font-weight: 800;
    border-bottom: 2px solid #000;
  }

  .vicca-button-container {
    display: flex;
    justify-content: center;
  }

  .vicca-button-group {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-orange {
    background-color: #FF914D;
    color: #fff !important;
    text-decoration: none;
    padding: 18px 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    border-radius: 100px;
    transition: 0.3s ease;
    white-space: nowrap;
    cursor: pointer;
  }

  .btn-black {
    background-color: #000;
    color: #fff !important;
    text-decoration: none;
    padding: 18px 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 700;
    border-radius: 100px;
    transition: 0.3s ease;
    white-space: nowrap;
    cursor: pointer;
  }

  .btn-orange:hover { background-color: #e87a3a; }
  .btn-black:hover { background-color: #222; }

  @media (max-width: 900px) {
    .vicca-content-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 24px;
    }

    .vicca-main-title .bold-font { letter-spacing: -1px; }

    .vicca-button-group {
      flex-direction: column;
      width: 100%;
      max-width: 340px;
      margin: 0 auto;
    }

    .btn-orange, .btn-black {
      width: 100%;
      padding: 16px 32px;
    }
  }
</style>