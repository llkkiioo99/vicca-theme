{% schema %}
{
  "name": "Affiliate Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF7F0"
    },
    {
      "type": "header",
      "content": "Botón Izquierdo (Naranja)"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Texto",
      "default": "Quiero afiliarme"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Enlace"
    },
    {
      "type": "header",
      "content": "Botón Derecho (Negro)"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Texto",
      "default": "Ya soy vicca.afiliate"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Enlace"
    }
  ],
  "presets": [
    {
      "name": "Affiliate Banner"
    }
  ]
}
{% endschema %}

<div class="vicca-banner-wrapper" style="background-color: {{ section.settings.bg_color }};">
  <div class="vicca-container">
    <div class="vicca-content-grid">
      
      <div class="vicca-title-area">
        <h2 class="vicca-main-title">
          <span class="serif-font">Programa de</span>
          <span class="bold-font">afiliados</span>
        </h2>
      </div>

      <div class="vicca-text-area">
        <p class="vicca-description">
          Conviértete en un <strong>vicca<span class="dot-orange">.</span>afiliate </strong> y ayuda a personas a empezar una nueva vida en Holanda con nuestro programa <span class="highlight-text">ganando dinero por ello.</span>
        </p>
      </div>

    </div>

    <div class="vicca-button-container">
      <div class="vicca-button-group">
        {%- if section.settings.button_1_text != blank -%}
          <a href="{{ section.settings.button_1_link | default: '#' }}" class="btn-orange">
            {{ section.settings.button_1_text }}
          </a>
        {%- endif -%}

        {%- if section.settings.button_2_text != blank -%}
          <a href="{{ section.settings.button_2_link | default: '#' }}" class="btn-black">
            {{ section.settings.button_2_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400&family=Poppins:wght@400;700;800;900&display=swap');

  .vicca-banner-wrapper {
    padding: 100px 5%;
    font-family: 'Poppins', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .vicca-container {
    max-width: 1100px;
    width: 100%;
  }

  .vicca-content-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
    margin-bottom: 80px;
  }

  .vicca-main-title {
    margin: 0;
    line-height: 0.85;
    color: #000;
  }

  .vicca-main-title .serif-font {
    font-family: 'Playfair Display', serif;
    font-size: clamp(45px, 6vw, 60px);
    display: block;
    font-weight: 400;
    margin-bottom: 10px;
  }

  .vicca-main-title .bold-font {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(55px, 8vw, 110px);
    font-weight: 900;
    display: block;
    letter-spacing: -3px;
    text-transform: lowercase;
  }

  /* --- Updated Description Styling --- */
  .vicca-description {
    font-size: clamp(22px, 3vw, 30px); /* সাইজ বাড়ানো হয়েছে */
    line-height: 1.4;
    color: #000;
    margin: 0;
    font-weight: 400;
  }

  .vicca-description strong {
    font-weight: 800;
  }

  .dot-orange {
    color: #FF914D; /* কমলা রঙ */
    font-weight: 900;
  }

  .highlight-text {
    text-decoration: underline;
    text-underline-offset: 4px;
    font-weight: 800;
    border-bottom: 2px solid #000;
    text-decoration: none; 
  }

  /* --- Button Styling --- */
  .vicca-button-container {
    display: flex;
    justify-content: center;
  }

  .vicca-button-group {
    display: inline-flex;
    align-items: center;
    background-color: #000;
    border-radius: 100px;
    padding: 0;
    height: 65px;
  }

  .btn-orange {
    background-color: #FF914D;
    color: #fff !important;
    text-decoration: none;
    padding: 0 50px;
    height: 100%;
    display: flex;
    align-items: center;
    font-size: 18px;
    font-weight: 700;
    border-radius: 100px;
    transition: 0.3s ease;
    white-space: nowrap;
    z-index: 2;
  }

  .btn-black {
    background-color: transparent;
    color: #fff !important;
    text-decoration: none;
    padding: 0 40px 0 30px; 
    height: 100%;
    display: flex;
    align-items: center;
    font-size: 18px;
    font-weight: 700;
    transition: 0.3s ease;
    white-space: nowrap;
  }

  .btn-orange:hover {
    background-color: #e87a3a;
  }

  .btn-black:hover {
    opacity: 0.8;
  }

  /* --- Responsive Adjustments --- */
  @media (max-width: 900px) {
    .vicca-content-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 30px;
    }
    
    .vicca-main-title .bold-font {
        letter-spacing: -1px;
    }

    .vicca-button-group {
      flex-direction: column;
      height: auto;
      background-color: transparent;
      width: 100%;
    }

    .btn-orange, .btn-black {
      width: 100%;
      height: 60px;
      justify-content: center;
      border-radius: 100px;
      margin: 5px 0;
    }
    
    .btn-black {
        background-color: #000;
        padding: 0;
    }
  }
</style>