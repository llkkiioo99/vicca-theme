{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  .expectations-container {
    max-width: 1920px;
    margin: 0 auto;
    text-align: center;
    padding: 0 5%;
    font-family: 'Poppins', sans-serif;
  }

  /* --- Text Styles --- */
  .expectations-header h2 {
    font-size: 42px;
    font-weight: 800;
    font-family: 'Poppins', sans-serif;
    margin-bottom: 30px;
    color: #000;
  }

  .expectations-middle-text {
    font-size: 24px;
    line-height: 1.3;
    font-weight: 500;
    max-width: 900px;
    margin: 0 auto 30px auto;
    color: #000;
  }

  .expectations-description {
    font-size: 17px;
    line-height: 1.6;
    max-width: 1000px;
    margin: 0 auto 80px auto;
    color: #444;
  }

  /* --- Image Gallery (Arc Upward Effect) --- */
  .expectations-gallery {
    display: flex;
    justify-content: center;
    align-items: flex-end; /* Align to bottom to push sides up */
    gap: 20px;
    padding-top: 100px; /* Space for the uplifted cards */
    max-width: 1920px;
    margin: 0 auto;
  }

  .expectation-card {
    flex: 1;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 0.75;
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    transition: transform 0.3s ease;
  }

  .expectation-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* --- The Arc Upward Logic --- */
  /* Left side - High and tilted */
  .expectation-card:nth-child(1) { transform: translateY(-80px) rotate(-10deg); }
  .expectation-card:nth-child(2) { transform: translateY(-40px) rotate(-5deg); }
  
  /* Middle - Lower */
  .expectation-card:nth-child(3) { transform: translateY(0px) rotate(-2deg); }
  .expectation-card:nth-child(4) { transform: translateY(0px) rotate(2deg); }
  
  /* Right side - High and tilted */
  .expectation-card:nth-child(5) { transform: translateY(-40px) rotate(5deg); }
  .expectation-card:nth-child(6) { transform: translateY(-80px) rotate(10deg); }

  /* Responsive */
  @media screen and (max-width: 1024px) {
    .expectations-gallery { gap: 10px; }
    .expectation-card:nth-child(1), .expectation-card:nth-child(6) { transform: translateY(-40px) rotate(0); }
    .expectation-card:nth-child(2), .expectation-card:nth-child(5) { transform: translateY(-20px) rotate(0); }
  }

  @media screen and (max-width: 749px) {
    .expectations-gallery {
      flex-wrap: wrap;
      gap: 15px;
    }
    .expectation-card {
      flex: 0 0 45%;
      transform: none !important;
      aspect-ratio: 1;
    }
    .expectations-header h2 { font-size: 30px; }
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding">
  <div class="expectations-container">
    
    <div class="expectations-header">
      <h2>{{ section.settings.title }}</h2>
    </div>

    <div class="expectations-middle-text">
       {{ section.settings.middle_text }}
    </div>

    <div class="expectations-description">
      {{ section.settings.text_content }}
    </div>

    {% comment %} <div class="expectations-gallery">
      {%- for block in section.blocks -%}
        <div class="expectation-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" 
                 alt="{{ block.settings.image.alt | escape }}" 
                 loading="lazy">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div> {% endcomment %}
    
  </div>
</section>

{% schema %}
{
  "name": "Realistic Expectations",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Main Heading",
      "default": "Expectativas realistas"
    },
    {
      "type": "richtext",
      "id": "middle_text",
      "label": "Middle Bold Text Block",
      "default": "<p>Has de saber que <strong>no existe una fórmula mágica ni un camino rápido.</strong></p><p>Es importante entender que <strong>cada uno vive su propio proceso y este programa se adapta a cada persona.</strong></p>"
    },
    {
      "type": "richtext",
      "id": "text_content",
      "label": "Detailed Description",
      "default": "<p>Hay quienes encuentran alojamiento más rápido y otras que tardan más tiempo. Todo depende del momento, de la cantidad de viviendas disponibles, y del propietario o inquilinos.</p>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfaf3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "image_block",
      "name": "Image Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Realistic Expectations",
      "blocks": [
        { "type": "image_block" },
        { "type": "image_block" },
        { "type": "image_block" },
        { "type": "image_block" },
        { "type": "image_block" },
        { "type": "image_block" }
      ]
    }
  ]
}
{% endschema %}