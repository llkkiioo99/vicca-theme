{% schema %}
{
  "name": "Editorial Photo Gallery",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf9f3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_top_negative",
      "min": -200,
      "max": 0,
      "step": 5,
      "unit": "px",
      "label": "Move Up (Negative Margin)",
      "default": -50
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Photo Gallery"
    }
  ]
}
{% endschema %}

<style>
  .vicca-gallery-section {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top_negative }}px;
    position: relative;
    z-index: 10;
    overflow: hidden;
  }

  .vicca-gallery-track {
    display: flex;
    gap: 16px;
    padding: 30px 40px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .vicca-gallery-track::-webkit-scrollbar {
    display: none;
  }

  .vicca-gallery-card {
    flex-shrink: 0;
    scroll-snap-align: start;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    background: #fff;
    position: relative;
  }

  .vicca-gallery-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12);
  }

  /* Varied card sizes for editorial feel */
  .vicca-gallery-card:nth-child(3n+1) {
    width: 280px;
    height: 360px;
  }

  .vicca-gallery-card:nth-child(3n+2) {
    width: 240px;
    height: 320px;
  }

  .vicca-gallery-card:nth-child(3n+3) {
    width: 300px;
    height: 380px;
  }

  .vicca-gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .vicca-gallery-card:hover img {
    transform: scale(1.04);
  }

  /* Tablet */
  @media screen and (max-width: 1024px) {
    .vicca-gallery-track { padding: 24px 24px; gap: 14px; }
    .vicca-gallery-card:nth-child(3n+1) { width: 220px; height: 290px; }
    .vicca-gallery-card:nth-child(3n+2) { width: 200px; height: 260px; }
    .vicca-gallery-card:nth-child(3n+3) { width: 240px; height: 310px; }
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .vicca-gallery-section { margin-top: -30px; }
    .vicca-gallery-track { padding: 20px 16px; gap: 12px; }
    .vicca-gallery-card { border-radius: 16px; }
    .vicca-gallery-card:nth-child(3n+1) { width: 180px; height: 240px; }
    .vicca-gallery-card:nth-child(3n+2) { width: 160px; height: 210px; }
    .vicca-gallery-card:nth-child(3n+3) { width: 190px; height: 250px; }
  }

  @media screen and (max-width: 480px) {
    .vicca-gallery-track { padding: 16px 12px; gap: 10px; }
    .vicca-gallery-card:nth-child(3n+1) { width: 160px; height: 210px; }
    .vicca-gallery-card:nth-child(3n+2) { width: 140px; height: 185px; }
    .vicca-gallery-card:nth-child(3n+3) { width: 170px; height: 220px; }
    .vicca-gallery-card { border-radius: 14px; }
  }
</style>

<section class="vicca-gallery-section">
  <div class="vicca-gallery-track" id="vicca-gallery-track-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="vicca-gallery-card" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="Gallery Image {{ forloop.index }}"
            loading="lazy"
            width="300"
            height="400"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

<script>
(function() {
  var track = document.getElementById('vicca-gallery-track-{{ section.id }}');
  if (!track) return;

  // Auto-scroll animation
  var scrollSpeed = 0.5;
  var scrollPos = 0;
  var isPaused = false;
  var maxScroll = track.scrollWidth - track.clientWidth;

  function autoScroll() {
    if (!isPaused && maxScroll > 0) {
      scrollPos += scrollSpeed;
      if (scrollPos >= maxScroll) scrollPos = 0;
      track.scrollLeft = scrollPos;
    }
    requestAnimationFrame(autoScroll);
  }

  // Pause on hover/touch
  track.addEventListener('mouseenter', function() { isPaused = true; });
  track.addEventListener('mouseleave', function() { isPaused = false; scrollPos = track.scrollLeft; });
  track.addEventListener('touchstart', function() { isPaused = true; }, { passive: true });
  track.addEventListener('touchend', function() {
    setTimeout(function() { isPaused = false; scrollPos = track.scrollLeft; }, 2000);
  });

  // Recalculate on resize
  window.addEventListener('resize', function() {
    maxScroll = track.scrollWidth - track.clientWidth;
  });

  // Start auto-scroll after a brief delay
  setTimeout(function() { requestAnimationFrame(autoScroll); }, 1000);
})();
</script>