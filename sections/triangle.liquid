{% schema %}
{
  "name": "Editorial Photo Gallery",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf9f3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top_negative",
      "min": -200,
      "max": 0,
      "step": 5,
      "unit": "px",
      "label": "Move Up (Negative Margin)",
      "default": -50
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Photo Gallery"
    }
  ]
}
{% endschema %}

<style>
  .vg-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top_negative }}px;
    position: relative;
    z-index: 10;
    overflow: hidden;
  }

  .vg-strip {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 18px;
    padding: 40px 30px 20px;
    max-width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .vg-strip::-webkit-scrollbar { display: none; }

  .vg-card {
    flex-shrink: 0;
    scroll-snap-align: center;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
    background: #fff;
  }

  .vg-card:hover {
    transform: translateY(-8px) rotate(0deg) !important;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.15);
    z-index: 5;
  }

  .vg-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Varied sizes + slight rotations like the reference */
  .vg-card:nth-child(9n+1) { width: 200px; height: 280px; transform: rotate(-4deg); }
  .vg-card:nth-child(9n+2) { width: 180px; height: 240px; transform: rotate(2deg) translateY(-15px); }
  .vg-card:nth-child(9n+3) { width: 240px; height: 320px; transform: rotate(-1deg); }
  .vg-card:nth-child(9n+4) { width: 190px; height: 260px; transform: rotate(3deg) translateY(-10px); }
  .vg-card:nth-child(9n+5) { width: 220px; height: 300px; transform: rotate(-2deg); }
  .vg-card:nth-child(9n+6) { width: 170px; height: 230px; transform: rotate(4deg) translateY(-20px); }
  .vg-card:nth-child(9n+7) { width: 210px; height: 290px; transform: rotate(-3deg); }
  .vg-card:nth-child(9n+8) { width: 185px; height: 250px; transform: rotate(1deg) translateY(-12px); }
  .vg-card:nth-child(9n+9) { width: 230px; height: 310px; transform: rotate(-2deg); }

  /* Tablet */
  @media screen and (max-width: 1024px) {
    .vg-strip { gap: 14px; padding: 30px 20px 16px; }
    .vg-card:nth-child(9n+1) { width: 170px; height: 240px; }
    .vg-card:nth-child(9n+2) { width: 155px; height: 210px; }
    .vg-card:nth-child(9n+3) { width: 200px; height: 270px; }
    .vg-card:nth-child(9n+4) { width: 165px; height: 225px; }
    .vg-card:nth-child(9n+5) { width: 185px; height: 255px; }
    .vg-card:nth-child(9n+6) { width: 150px; height: 200px; }
    .vg-card:nth-child(9n+7) { width: 175px; height: 245px; }
    .vg-card:nth-child(9n+8) { width: 160px; height: 215px; }
    .vg-card:nth-child(9n+9) { width: 195px; height: 265px; }
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    .vg-section-{{ section.id }} { margin-top: -20px; }
    .vg-strip { gap: 10px; padding: 20px 12px 12px; }
    .vg-card { border-radius: 10px; }
    .vg-card:nth-child(9n+1) { width: 140px; height: 195px; }
    .vg-card:nth-child(9n+2) { width: 125px; height: 170px; }
    .vg-card:nth-child(9n+3) { width: 160px; height: 220px; }
    .vg-card:nth-child(9n+4) { width: 130px; height: 180px; }
    .vg-card:nth-child(9n+5) { width: 150px; height: 205px; }
    .vg-card:nth-child(9n+6) { width: 120px; height: 165px; }
    .vg-card:nth-child(9n+7) { width: 145px; height: 200px; }
    .vg-card:nth-child(9n+8) { width: 130px; height: 175px; }
    .vg-card:nth-child(9n+9) { width: 155px; height: 215px; }
    /* Less rotation on mobile */
    .vg-card:nth-child(9n+1) { transform: rotate(-2deg); }
    .vg-card:nth-child(9n+2) { transform: rotate(1deg) translateY(-8px); }
    .vg-card:nth-child(9n+3) { transform: rotate(-1deg); }
    .vg-card:nth-child(9n+4) { transform: rotate(2deg) translateY(-5px); }
    .vg-card:nth-child(9n+5) { transform: rotate(-1deg); }
    .vg-card:nth-child(9n+6) { transform: rotate(2deg) translateY(-10px); }
    .vg-card:nth-child(9n+7) { transform: rotate(-1deg); }
    .vg-card:nth-child(9n+8) { transform: rotate(1deg) translateY(-6px); }
    .vg-card:nth-child(9n+9) { transform: rotate(-1deg); }
  }
</style>

<section class="vg-section-{{ section.id }}">
  <div class="vg-strip">
    {% for block in section.blocks %}
      <div class="vg-card" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="Gallery {{ forloop.index }}"
            loading="lazy"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>