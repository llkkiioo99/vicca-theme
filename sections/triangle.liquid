{% schema %}
{
  "name": "Editorial Photo Gallery",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf9f3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top_negative",
      "min": -200,
      "max": 0,
      "step": 5,
      "unit": "px",
      "label": "Move Up (Negative Margin)",
      "default": -50
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "s",
      "label": "Rotation Speed (seconds per full turn)",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Photo Gallery"
    }
  ]
}
{% endschema %}

<style>
  /* ── Section ── */
  .vg-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top_negative }}px;
    margin-bottom: 60px;
    position: relative;
    z-index: 10;
    overflow: hidden;
  }

  /* ── Visual container — edge fade mask (exact Flowblox) ── */
  .vg-visual-{{ section.id }} {
    position: relative;
    width: 1600px;
    max-width: 100vw;
    height: 520px;
    margin: 0 auto;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-mask: linear-gradient(90deg, rgba(0,0,0,0) 0%, rgba(0,0,0,1) 19.7%, rgba(0,0,0,1) 80%, rgba(0,0,0,0) 100%);
    mask: linear-gradient(90deg, rgba(0,0,0,0) 0%, rgba(0,0,0,1) 19.7%, rgba(0,0,0,1) 80%, rgba(0,0,0,0) 100%);
  }

  /* ── Slider (perspective parent — exact Flowblox: perspective 600px) ── */
  .vg-slider-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1px;
    flex: 1 0 0;
    transform: perspective(600px);
    transform-style: preserve-3d;
  }

  /* ── Circle (rotating element) ── */
  .vg-circle-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    width: 1px;
    flex: 1 0 0;
    transform-style: preserve-3d;
    animation: vg-spin-{{ section.id }} {{ section.settings.speed }}s linear infinite;
  }

  @keyframes vg-spin-{{ section.id }} {
    from { transform: rotateY(0deg); }
    to   { transform: rotateY(360deg); }
  }

  /* ── Card slot (Flowblox cylinder radius) ── */
  .vg-slot-{{ section.id }} {
    position: absolute;
    width: 1400px;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transform-style: preserve-3d;
    left: calc(50% - 700px);
    top: calc(50% - 200px);
    z-index: 1;
  }

  /* ── Card face ── */
  .vg-face-{{ section.id }} {
    width: 280px;
    height: 400px;
    border-radius: 20px;
    overflow: hidden;
    backface-visibility: hidden;
    flex: none;
    position: relative;
    will-change: transform;
  }

  .vg-face-{{ section.id }} img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  /* ── Tablet ── */
  @media screen and (max-width: 1024px) {
    .vg-visual-{{ section.id }} { height: 420px; }
    .vg-slot-{{ section.id }} { width: 1000px; height: 300px; left: calc(50% - 500px); top: calc(50% - 150px); }
    .vg-face-{{ section.id }} { width: 220px; height: 300px; border-radius: 18px; }
  }

  /* ── Mobile ── */
  @media screen and (max-width: 768px) {
    .vg-section-{{ section.id }} { margin-top: -20px; }
    .vg-visual-{{ section.id }} { height: 320px; }
    .vg-slot-{{ section.id }} { width: 700px; height: 220px; left: calc(50% - 350px); top: calc(50% - 110px); }
    .vg-face-{{ section.id }} { width: 160px; height: 220px; border-radius: 16px; }
  }

  @media screen and (max-width: 480px) {
    .vg-visual-{{ section.id }} { height: 260px; }
    .vg-slot-{{ section.id }} { width: 500px; height: 170px; left: calc(50% - 250px); top: calc(50% - 85px); }
    .vg-face-{{ section.id }} { width: 120px; height: 170px; border-radius: 14px; }
  }
</style>

<section class="vg-section-{{ section.id }}">
  <div class="vg-visual-{{ section.id }}">
    <div class="vg-slider-{{ section.id }}">
      <div class="vg-circle-{{ section.id }}">
        {%- assign total = section.blocks.size -%}
        {%- if total > 0 -%}
          {%- comment -%}
            Flowblox uses 6 slots at 30° intervals (30, 60, 90, 120, 150, 180).
            Each slot has front face (rotateY 90°) and back face (rotateY -90°).
            We use the same fixed 30° step regardless of image count.
          {%- endcomment -%}
          {%- assign slot_count = 6 -%}
          {%- assign angle_step = 30 -%}
          {%- assign img_index = 0 -%}

          {%- for i in (1..slot_count) -%}
            {%- assign slot_angle = i | times: angle_step -%}
            {%- assign front_idx = img_index -%}
            {%- assign img_index = img_index | plus: 1 -%}
            {%- if img_index >= total -%}{%- assign img_index = 0 -%}{%- endif -%}
            {%- assign back_idx = img_index -%}
            {%- assign img_index = img_index | plus: 1 -%}
            {%- if img_index >= total -%}{%- assign img_index = 0 -%}{%- endif -%}

            <div class="vg-slot-{{ section.id }}" style="transform: rotateY({{ slot_angle }}deg);">
              <div class="vg-face-{{ section.id }}" style="transform: rotateY(90deg);">
                {% if section.blocks[front_idx].settings.image != blank %}
                  <img src="{{ section.blocks[front_idx].settings.image | image_url: width: 600 }}" alt="Gallery {{ front_idx | plus: 1 }}" loading="lazy">
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              <div class="vg-face-{{ section.id }}" style="transform: rotateY(-90deg);">
                {% if section.blocks[back_idx].settings.image != blank %}
                  <img src="{{ section.blocks[back_idx].settings.image | image_url: width: 600 }}" alt="Gallery {{ back_idx | plus: 1 }}" loading="lazy">
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
