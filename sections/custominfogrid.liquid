{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

  .info-grid-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    font-family: 'Poppins', sans-serif;
    /* Efecto curvo superior similar a la imagen */
    clip-path: ellipse(150% 100% at 50% 100%);
  }

  .info-grid-header h2 {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(32px, 5vw, 35px);
    font-weight: 700;
    margin-bottom: 60px;
    color: #000;
    text-align: center;
    letter-spacing: -0.5px;
  }

  .info-grid-wrapper {
    display: grid;
    grid-template-columns: 1fr minmax(300px, 550px) 1fr;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    padding: 0 20px;
    box-sizing: border-box;
  }

  .info-grid-center {
    grid-column: 2;
    z-index: 1;
    display: flex;
    justify-content: center;
  }

  .info-grid-center img {
    width: 100%;
    max-width: 650px;
    height: auto;
    border-radius: 30px;
    display: block;
    object-fit: cover;
  }

  .info-side-col {
    display: flex;
    flex-direction: column;
    gap: 30px; 
    z-index: 10;
  }

  /* --- ALINEACIÓN DINÁMICA --- */
  .left-col {
    grid-column: 1;
    align-items: flex-end;
    margin-right: -60px;
  }

  .right-col {
    grid-column: 3;
    align-items: flex-start;
    margin-left: -60px;
  }

  .info-card {
    background: rgba(255, 255, 255, 0.9); 
    backdrop-filter: blur(1px);
    -webkit-backdrop-filter: blur(1px);
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    width: 100%;
    max-width: 380px;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.5);
    transition: transform 0.3s ease;
  }

  /* Posicionamiento de los números según el lado */
  .left-col .info-card { text-align: left; align-items: flex-start; }
  .right-col .info-card { text-align: right; align-items: flex-end; }

  .info-card-badge {
    display: flex;
    margin-bottom: 15px;
  }

  /* Invertir el orden de las bolitas en la columna derecha */
  /* .right-col .info-card-badge {
    flex-direction: row-reverse;
  } */

  .badge-num, .badge-total {
    width: 35px;
    height: 35px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
  }

  .badge-num {
    background: #ff914d;
    color: #fff;
    z-index: 2;
  }

  .badge-total {
    background: #fdd8c5;
    color: #ff914d;
    z-index: 1;
  }

  /* Ajuste de solapamiento de números según el lado */
  .left-col .badge-total { margin-left: -12px; padding-left: 8px; }
  .right-col .badge-total { margin-left: -12px; padding-right: 8px; }

  .info-card h3 {
    font-size: 20px;
    margin: 0 0 10px 0;
    font-weight: 700;
    color: #000;
  }

  .info-card p {
    font-size: 14px;
    color: #555;
    line-height: 1.5;
    margin: 0;
  }

  /* Tablet */
  @media (max-width: 1100px) {
    .info-grid-wrapper {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .info-grid-center { grid-column: 1; order: -1; }
    .left-col, .right-col {
      grid-column: 1;
      margin: 0;
      align-items: center;
      text-align: center;
    }
    .left-col .info-card, .right-col .info-card {
      align-items: center;
      text-align: center;
      max-width: 100%;
    }
    .info-card-badge { flex-direction: row !important; }
    .badge-total { margin-left: -12px !important; margin-right: 0 !important; padding-left: 8px !important; }
    .info-grid-center img { max-width: 100%; border-radius: 20px; }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .info-grid-{{ section.id }} {
      clip-path: none;
      padding-top: 60px;
      padding-bottom: 60px;
    }
    .info-grid-header h2 { font-size: 26px; margin-bottom: 36px; }
    .info-card { padding: 24px; min-height: auto; max-width: 100%; }
    .info-card h3 { font-size: 18px; }
  }

  @media (max-width: 480px) {
    .info-grid-{{ section.id }} { padding-top: 40px; padding-bottom: 40px; }
    .info-card { padding: 20px; border-radius: 16px; }
  }
{%- endstyle -%}

<section class="info-grid-{{ section.id }}">
  <div class="info-grid-header">
    <h2>{{ section.settings.title }}</h2>
  </div>

  <div class="info-grid-wrapper">
    <div class="info-side-col left-col">
      {% for block in section.blocks limit: 2 %}
        <div class="info-card" {{ block.shopify_attributes }}>
          <div class="info-card-badge">
            <span class="badge-num">0{{ forloop.index }}</span>
            <span class="badge-total">04</span>
          </div>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>

    <div class="info-grid-center">
      {% if section.settings.center_image != blank %}
        {{ section.settings.center_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.title }}
      {% else %}
        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    <div class="info-side-col right-col">
      {% for block in section.blocks offset: 2 %}
        <div class="info-card" {{ block.shopify_attributes }}>
          <div class="info-card-badge">
            <span class="badge-num">0{{ forloop.index | plus: 2 }}</span>
            <span class="badge-total">04</span>
          </div>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Info Grid",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la Sección",
      "default": "Cómo lo hacemos posible"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Imagen Central"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#fdfaf5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "info_card",
      "name": "Tarjeta de Información",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Encabezado",
          "default": "Título"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto corto",
          "default": "Descripción aquí"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Info Grid",
      "blocks": [
        { "type": "info_card", "settings": { "heading": "Adaptación completa", "text": "Desde la idea de mudarte hasta la completa integración..." } },
        { "type": "info_card", "settings": { "heading": "Experiencia multicultural", "text": "Te ayudamos a adaptarte a la cultura holandesa..." } },
        { "type": "info_card", "settings": { "heading": "Acompañamiento real y personal", "text": "Te guiamos con honestidad en cada paso del proceso." } },
        { "type": "info_card", "settings": { "heading": "Trámites simplificados", "text": "Evitamos errores y confusiones en la burocracia." } }
      ]
    }
  ]
}
{% endschema %}