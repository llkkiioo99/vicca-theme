{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap');

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    font-family: 'Poppins', sans-serif;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .info-grid-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .info-grid-title {
    text-align: center;
    font-family: 'Poppins', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 70px;
    color: #000;
    line-height: 1.2;
  }

  .info-grid-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 50px;
    align-items: center;
  }

  @media (min-width: 990px) {
    .info-grid-content {
      grid-template-columns: 1.1fr 1fr;
      gap: 80px;
    }
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    margin-bottom: 40px;
  }

  .info-item:last-child {
    margin-bottom: 0;
  }

  .info-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    margin-right: 18px;
    margin-top: 4px;
  }

  .info-text {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    line-height: 1.5;
    color: #000;
  }

  .info-text p {
    margin: 0;
  }

  .info-text strong {
    font-weight: 800;
    color: #000;
  }

  .info-image-wrapper img {
    width: 100%;
    height: auto;
    border-radius: 30px;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .info-grid-title {
      font-size: 1.8rem;
      margin-bottom: 40px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="info-grid-container">
    {% if section.settings.title != blank %}
      <h2 class="info-grid-title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="info-grid-content">
      <div class="info-list-wrapper">
        <ul class="info-list">
          {% for block in section.blocks %}
            <li class="info-item" {{ block.shopify_attributes }}>
              <div class="info-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="12" cy="12" r="10" fill="#F4934E"/>
                  <path d="M8 12L11 15L16 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="info-text">
                {{ block.settings.text }}
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="info-image-wrapper">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Relocation Info Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Este programa es para ti si..."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side Image"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Info Point",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text Content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Relocation Info Grid",
      "blocks": [
        { 
          "type": "text_block",
          "settings": {
            "text": "<p>Si tienes la <strong>actitud</strong>, el <strong>compromiso</strong>, la <strong>valentía</strong> y la <strong>flexibilidad para adaptarte a lo nuevo</strong>, entonces este camino está hecho para ti.</p>"
          }
        },
        { 
          "type": "text_block",
          "settings": {
            "text": "<p>Si estás <strong>dispuesto a dejarte asesorar y guiar</strong> por un equipo de expertos, y <strong>mirar los cambios como una oportunidad.</strong></p>"
          }
        },
        { 
          "type": "text_block",
          "settings": {
            "text": "<p><strong>Si quieres</strong> transformar lo que puede ser el caos de mudarse a otro país, en <strong>una experiencia increíble que nunca olvidarás.</strong></p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}