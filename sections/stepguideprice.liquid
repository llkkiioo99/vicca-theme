{% comment %}
  Custom Pricing Section - Poppins for Title, Playfair Display for Subtitle.
{% endcomment %}

<style>
  /* Importación de fuentes: Poppins y Playfair Display */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:wght@400;700&display=swap');

  #shopify-section-{{ section.id }} .price-wrapper {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    text-align: center;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .price-content {
    max-width: 90%;
    width: 800px;
    margin: 0 auto;
  }

  /* Estilo para "Precio" - Poppins */
  #shopify-section-{{ section.id }} .price-title {
    font-family: 'Poppins', sans-serif;
    font-size: 38px;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    margin: 0 0 10px 0;
    letter-spacing: -0.5px;
  }

  /* Estilo para "*Pago único" - Playfair Display */
  #shopify-section-{{ section.id }} .price-subtitle {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 400;
    color: #8c8c8c;
    margin: 0 0 30px 0;
    font-style: italic; /* Opcional: Playfair luce genial en cursiva */
  }

  /* Estilo para el Precio - Diseño según imagen */
  #shopify-section-{{ section.id }} .price-display {
    font-family: 'Poppins', sans-serif;
    font-size: 50px; /* Tamaño grande para Desktop */
    font-weight: 600;
    color: {{ section.settings.price_color }};
    line-height: 0.9;
    margin: 0;
    letter-spacing: -2px;
    display: inline-block;
  }

  /* --- RESPONSIVE DESIGN --- */

  /* Laptops y Tablets (1024px) */
  @media (max-width: 1024px) {
    #shopify-section-{{ section.id }} .price-display {
      font-size: 50px;
    }
    #shopify-section-{{ section.id }} .price-title {
      font-size: 32px;
    }
  }

  /* Móviles (767px o menos) */
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .price-wrapper {
      padding-top: 60px;
      padding-bottom: 60px;
    }
    #shopify-section-{{ section.id }} .price-title {
      font-size: 28px;
    }
    #shopify-section-{{ section.id }} .price-subtitle {
      font-size: 18px;
      margin-bottom: 20px;
    }
    #shopify-section-{{ section.id }} .price-display {
      font-size: 50px; /* Tamaño ajustado para pantallas pequeñas */
      letter-spacing: -1px;
    }
  }
</style>

<div class="price-wrapper">
  <div class="price-content">
    <h2 class="price-title">{{ section.settings.title }}</h2>
    <p class="price-subtitle">{{ section.settings.subtitle }}</p>
    <div class="price-display">{{ section.settings.price_text }}</div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Price Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Precio"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "*Pago único"
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Price Text",
      "default": "49€"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf9f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#ff9f5f"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 150
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 250,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 150
    }
  ],
  "presets": [
    {
      "name": "Custom Price Section"
    }
  ]
}
{% endschema %}