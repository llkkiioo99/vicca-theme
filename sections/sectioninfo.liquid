{% schema %}
{
  "name": "Step Into Opportunity",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FDF9F3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (Orange) Color",
      "default": "#FF8A5B"
    }
  ],
  "presets": [
    {
      "name": "Step Into Opportunity"
    }
  ]
}
{% endschema %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:wght@300;400;600;700;800&display=swap');
</style>

<section class="step-opportunity-wrapper" style="background-color: {{ section.settings.bg_color }};">
  <div class="diagonal-top"></div>

  <div class="step-container">
    <div class="step-header">
      <span class="step-logo-top">Step Into</span><br>
      <span class="step-logo-bottom">Opportunity</span>
    </div>

    <div class="step-content-body">
      <h2 class="step-main-title">Descubre si este<br>programa es para ti</h2>

      <div class="step-intro">
        <p class="step-bold-text">
          Este formulario nos permite asegurarnos de que podemos ayudarte de forma personalizada y efectiva.
        </p>
        <p class="step-small-text">
          Si cumples con estos puntos, ¡estás listo/a para dar el salto! Podrás agendar una llamada con nuestro equipo, donde resolveremos todas tus dudas y te explicaremos en detalle cómo te acompañaremos paso a paso.
        </p>
      </div>

      <div class="step-question-box">
        <h3 class="step-subheading">¿Aún no cumples con todos los requisitos?</h3>
        <p class="step-small-text">
          ¡No pasa nada! Contáctanos por WhatsApp para que podamos conocer tu caso, saber en qué punto estás e informarte y orientarte a tener todo listo, sin compromiso.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .step-opportunity-wrapper {
    position: relative;
    padding: 100px 20px 120px;
    overflow: hidden;
    color: #000000;
    font-family: 'Poppins', sans-serif; /* Default Font */
    display: flex;
    justify-content: center;
  }

  /* The diagonal shape background */
  .diagonal-top {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 400px; /* Tall enough to cover the header area */
    background-color: #ffffff;
    clip-path: polygon(0 0, 100% 0, 100% 20%, 0% 100%);
    z-index: 1;
  }

  .step-container {
    position: relative;
    z-index: 2;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }

  /* Playfair Display for the Brand */
  .step-header {
    margin-bottom: 80px;
    line-height: 1.1;
    font-family: 'Playfair Display', serif;
  }

  .step-logo-top {
    font-size: 32px;
    font-weight: 500;
  }

  .step-logo-bottom {
    font-size: 36px;
      font-family: 'Poppins', sans-serif; 
    font-weight: 900;
    display: inline-block;
  }

  /* Content area */
  .step-content-body {
    max-width: 800px;
  }

  .step-main-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 800;
    margin-bottom: 50px;
    line-height: 1.1;
    letter-spacing: -1.5px;
  }

  .step-bold-text {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 25px;
    line-height: 1.3;
    max-width: 750px;
  }

  .step-small-text {
    font-size: 16px;
    line-height: 1.6;
    color: #1a1a1a;
    margin-bottom: 30px;
    max-width: 780px;
    font-weight: 400;
  }

  .step-subheading {
    font-family: 'Poppins', sans-serif;
    font-size: 24px;
    font-weight: 800;
    margin-top: 50px;
    margin-bottom: 15px;
    letter-spacing: -0.5px;
  }

  /* Mobile Responsive Tweaks */
  @media screen and (max-width: 768px) {
    .step-opportunity-wrapper {
      padding: 60px 20px 80px;
    }
    
    .diagonal-top {
      height: 300px;
      clip-path: polygon(0 0, 100% 0, 100% 40%, 0% 100%);
    }

    .step-header {
      margin-bottom: 60px;
    }

    .step-logo-top { font-size: 26px; }
    .step-logo-bottom { font-size: 30px; }

    .step-main-title {
      font-size: 38px;
      margin-bottom: 30px;
    }

    .step-bold-text {
      font-size: 18px;
    }

    .step-subheading {
      font-size: 20px;
    }
  }
</style>