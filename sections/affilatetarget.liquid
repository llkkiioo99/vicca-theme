{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');

  .afft-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    font-family: 'Poppins', sans-serif;
  }

  .afft-container {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .afft-card {
    background: #fff;
    border-radius: 32px;
    padding: 48px 44px;
    box-shadow: 0 6px 30px rgba(0,0,0,0.05);
  }

  .afft-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #ff914d;
    margin: 0 0 16px;
  }

  .afft-heading {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(24px, 3vw, 30px);
    font-weight: 800;
    color: #000;
    margin: 0 0 8px;
    letter-spacing: -0.5px;
    line-height: 1.2;
  }

  .afft-intro {
    font-size: 15px;
    font-weight: 500;
    color: #666;
    margin: 0 0 28px;
    line-height: 1.5;
  }

  .afft-list {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
  }

  .afft-list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 12px 0;
    font-size: 15px;
    color: #222;
    line-height: 1.4;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .afft-list li:last-child { border-bottom: none; }

  .afft-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #ff914d;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .afft-footer {
    font-size: 16px;
    font-weight: 700;
    color: #000;
    text-align: center;
    margin: 0;
    padding-top: 20px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  @media (max-width: 768px) {
    .afft-card { padding: 36px 28px; border-radius: 24px; }
    .afft-heading { font-size: 24px; }
  }

  @media (max-width: 480px) {
    .afft-card { padding: 28px 22px; border-radius: 20px; }
    .afft-heading { font-size: 22px; }
    .afft-list li { font-size: 14px; padding: 10px 0; }
    .afft-intro { font-size: 14px; }
    .afft-footer { font-size: 15px; }
    .afft-container { padding: 0 16px; }
  }
{%- endstyle -%}

<div class="afft-section-{{ section.id }}">
  <div class="afft-container">
    <div class="afft-card">
      <p class="afft-label">Para ti si...</p>
      <h2 class="afft-heading">{{ section.settings.heading }}</h2>
      <p class="afft-intro">{{ section.settings.intro_text }}</p>

      <ul class="afft-list">
        {%- if section.settings.point_1 != blank -%}
          <li><span class="afft-check">&#10003;</span><span>{{ section.settings.point_1 }}</span></li>
        {%- endif -%}
        {%- if section.settings.point_2 != blank -%}
          <li><span class="afft-check">&#10003;</span><span>{{ section.settings.point_2 }}</span></li>
        {%- endif -%}
        {%- if section.settings.point_3 != blank -%}
          <li><span class="afft-check">&#10003;</span><span>{{ section.settings.point_3 }}</span></li>
        {%- endif -%}
        {%- if section.settings.point_4 != blank -%}
          <li><span class="afft-check">&#10003;</span><span>{{ section.settings.point_4 }}</span></li>
        {%- endif -%}
      </ul>

      <p class="afft-footer">{{ section.settings.footer_bold_text }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Affiliate Target Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfaf4"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "¿A quién va dirigido el programa de afiliados?"
    },
    {
      "type": "text",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "Este programa está pensado para personas que:"
    },
    {
      "type": "text",
      "id": "point_1",
      "label": "Point 1",
      "default": "Creen en hacer las cosas bien, sin atajos"
    },
    {
      "type": "text",
      "id": "point_2",
      "label": "Point 2",
      "default": "Valoran el acompañamiento real frente a las promesas vacías"
    },
    {
      "type": "text",
      "id": "point_3",
      "label": "Point 3",
      "default": "Recomiendan desde la honestidad, no desde la presión"
    },
    {
      "type": "text",
      "id": "point_4",
      "label": "Point 4",
      "default": "Prefieren construir confianza antes que volumen"
    },
    {
      "type": "text",
      "id": "footer_bold_text",
      "label": "Footer Bold Text",
      "default": "Queremos pocos afiliados, pero alineados."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Affiliate Target Section"
    }
  ]
}
{% endschema %}
