{% schema %}
{
  "name": "Custom Testimonial Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Esto es lo que dicen nuestros cliente"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf8f3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "user_image",
          "label": "Client Image"
        },
        {
          "type": "text",
          "id": "client_name",
          "label": "Client Name/Location",
          "default": "Michelle – California (USA)"
        },
        {
          "type": "textarea",
          "id": "testimonial_text",
          "label": "Testimonial Text",
          "default": "I'm Michelle, from California..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Testimonial Slider"
    }
  ]
}
{% endschema %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,600;0,700;1,400&display=swap');

  .testimonial-section-{{ section.id }} { 
    padding-top: {{ section.settings.padding_top }}px; 
    padding-bottom: {{ section.settings.padding_bottom }}px; 
    background-color: {{ section.settings.bg_color }};
    font-family: 'Poppins', sans-serif !important;
  }
  
  .testimonial-container { 
    max-width: 1200px; 
    margin: 0 auto; 
    padding: 0 40px;
    position: relative;
  }
  
  .testimonial-title {
    text-align: center;
    font-family: 'Poppins', sans-serif !important;
    font-size: 36px;
    font-weight: 800;
    margin-bottom: 130px; 
    color: #000;
    letter-spacing: -0.5px;
  }

  .testimonial-slider-wrapper { 
    position: relative;
    display: flex;
    align-items: center;
  }

  .testimonial-slide { 
    display: none; 
    width: 100%; 
  }

  .testimonial-slide.active { 
    display: flex; 
    justify-content: center;
    align-items: center;
    gap: 60px; /* Gap between image and text */
    animation: fadeIn 0.5s ease-in-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .testimonial-image-wrapper {
    flex: 0 0 350px; 
    height: 350px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .main-img { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
  }

  .testimonial-text-wrapper { 
    flex: 0 1 550px; /* Fixed width for text area */
  }

  .client-name { 
    color: #ff8c42; /* Matching the orange in pic */
    font-size: 28px; 
    font-weight: 700;
    font-family: 'Poppins', sans-serif !important;
    margin-bottom: 20px; 
  }

  .testimonial-body { 
    font-size: 14.5px; 
    font-family: 'Poppins', sans-serif !important;
    line-height: 1.7; 
    color: #555; 
    font-style: italic;
    font-weight: 400;
  }

  /* Navigation Buttons - Positioned like the image */
  .nav-btn { 
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    border: none; 
    border-radius: 50%; 
    width: 50px; 
    height: 50px; 
    cursor: pointer; 
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: 0.3s;
    font-size: 20px;
    color: white;
  }

  .prev-btn { 
    left: -20px; 
    background: #000; 
  }

  .next-btn { 
    right: -20px; 
    background: #ff8c42; 
  }

  .nav-btn:hover { opacity: 0.8; transform: translateY(-50%) scale(1.05); }

  @media (max-width: 1024px) {
    .testimonial-slide.active { gap: 30px; }
    .testimonial-image-wrapper { flex: 0 0 300px; height: 300px; }
  }

  @media (max-width: 768px) {
    .testimonial-slide.active { flex-direction: column; text-align: center; }
    .testimonial-image-wrapper { flex: 0 0 280px; width: 280px; height: 280px; }
    .nav-btn { position: relative; top: 0; transform: none; margin: 20px 10px; display: inline-flex; }
    .testimonial-slider-wrapper { display: block; text-align: center; }
    .testimonial-title { margin-bottom: 40px; }
  }
</style>

<section class="testimonial-section-{{ section.id }}">
  <div class="testimonial-container">
    {% if section.settings.heading != blank %}
      <h2 class="testimonial-title">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="testimonial-slider-wrapper">
      <button class="nav-btn prev-btn" onclick="moveSlide(-1)">❮</button>

      {% for block in section.blocks %}
        <div class="testimonial-slide {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            
            <div class="testimonial-image-wrapper">
              {% if block.settings.user_image %}
                <img src="{{ block.settings.user_image | img_url: '800x800', crop: 'center' }}" alt="{{ block.settings.client_name }}" class="main-img">
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>

            <div class="testimonial-text-wrapper">
              <h3 class="client-name">{{ block.settings.client_name }}</h3>
              <div class="testimonial-body">
                {{ block.settings.testimonial_text }}
              </div>
            </div>

        </div>
      {% endfor %}

      <button class="nav-btn next-btn" onclick="moveSlide(1)">❯</button>
    </div>
  </div>
</section>

<script>
let currentIdx = 0;
function moveSlide(direction) {
  const container = document.querySelector('.testimonial-section-{{ section.id }}');
  const slides = container.querySelectorAll('.testimonial-slide');
  
  slides[currentIdx].classList.remove('active');
  
  currentIdx += direction;
  
  if (currentIdx >= slides.length) {
    currentIdx = 0;
  } else if (currentIdx < 0) {
    currentIdx = slides.length - 1;
  }
  
  slides[currentIdx].classList.add('active');
}
</script>