{% schema %}
{
  "name": "Step Into Guide Banner",
  "settings": [
    {
      "type": "product",
      "id": "selected_product",
      "label": "Select Product"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image (Override)"
    },
    {
      "type": "text",
      "id": "header_top",
      "label": "Top Left Title",
      "default": "Step Into"
    },
    {
      "type": "text",
      "id": "header_bottom",
      "label": "Top Left Subtitle",
      "default": "Guide"
    },
    {
      "type": "text",
      "id": "main_title",
      "label": "Main Headline",
      "default": "Ready to take the first step?"
    },
    {
      "type": "text",
      "id": "product_name",
      "label": "Product Name Display",
      "default": "Digital Practical Guide – Step Into Guide"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price Display",
      "default": "49€"
    }
  ],
  "presets": [
    {
      "name": "Step Into Guide Banner"
    }
  ]
}
{% endschema %}

{%- assign product = section.settings.selected_product -%}
{%- assign variant_id = product.selected_or_first_available_variant.id -%}

<section class="step-into-banner">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:wght@300;400;600;700;800&display=swap');
  </style>

  <div class="diagonal-bg"></div>
  
  <div class="top-logo-text">
    <span class="light-font">{{ section.settings.header_top }}</span><br>
    <span class="bold-font">{{ section.settings.header_bottom }}</span>
  </div>

  <div class="banner-container">
    <div class="banner-image-col">
      <div class="book-wrapper">
        {% if section.settings.product_image != blank %}
          <img src="{{ section.settings.product_image | img_url: '600x' }}" alt="Guide Book" class="guide-img">
        {% elsif product.featured_image != blank %}
          <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title }}" class="guide-img">
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg guide-img' }}
        {% endif %}
        <div class="book-shadow"></div>
      </div>
    </div>

    <div class="banner-content-col">
      <h1 class="main-headline">{{ section.settings.main_title }}</h1>
      <p class="product-title">{{ section.settings.product_name }}</p>
      
      <div class="price-section">
        <span class="main-price">{{ section.settings.price }}</span>
        <span class="sub-price">*Pago único</span>
      </div>
      
      {%- if product != blank -%}
        <form action="/cart/add" method="post" enctype="multipart/form-data">
          <input type="hidden" name="id" value="{{ variant_id }}">
          <input type="hidden" name="return_to" value="/cart">

          <div class="action-row">
            <div class="quantity-selector">
              <button type="button" class="qty-btn" onclick="this.parentNode.querySelector('input[type=number]').stepDown()">-</button>
              <input type="number" name="quantity" value="1" min="1" class="qty-input" readonly>
              <button type="button" class="qty-btn" onclick="this.parentNode.querySelector('input[type=number]').stepUp()">+</button>
            </div>
            
            <button type="submit" class="add-to-cart-btn">Añadir al carrito</button>
          </div>
        </form>
      {%- else -%}
        <p class="error-msg">Please select a product in the section settings.</p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* Base Styles */
  .step-into-banner {
    position: relative;
    padding: 100px 5%;
    overflow: hidden;
    background-color: #ffffff; 
    font-family: 'Poppins', sans-serif;
    display: flex;
    align-items: center;
    min-height: 80vh;
  }

  .top-logo-text {
    position: absolute;
    top: 40px;
    left: 5%;
    z-index: 10;
    line-height: 1.1;
    font-family: 'Playfair Display', serif;
  }

  .top-logo-text .light-font { font-size: 24px; font-weight: 400; color: #000; }
  .top-logo-text .bold-font { font-size: 30px; font-weight: 800; color: #000; }

  .diagonal-bg {
    position: absolute;
    top: 100px;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #fdf8f4;
    clip-path: polygon(0 15%, 100% 5%, 100% 100%, 0 100%);
    z-index: 1;
  }

  .banner-container {
    position: relative;
    z-index: 5;
    display: flex;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    align-items: center;
    justify-content: center;
    gap: 40px;
  }

  /* Image Column & Dimensions */
  .banner-image-col { 
    flex: 1; 
    display: flex; 
    justify-content: center;
    min-width: 300px;
  }
  
  .book-wrapper { position: relative; display: inline-block; z-index: 2; }
  
  .guide-img { 
    width: 280px; 
    height: 300px;
    object-fit: contain; /* Keeps aspect ratio within fixed size */
    transform: rotate(-3deg); 
    display: block;
    position: relative;
    z-index: 3;
    transition: transform 0.3s ease;
  }

  .book-shadow {
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%) rotate(-3deg);
    width: 80%;
    height: 20px;
    background: radial-gradient(ellipse at center, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0) 70%);
    filter: blur(8px);
    z-index: 1;
  }

  /* Content Column */
  .banner-content-col { 
    flex: 1.2; 
    min-width: 300px;
    text-align: left;
  }

  .main-headline {
    font-size: clamp(32px, 5vw, 50px); /* Responsive font size */
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
    margin-bottom: 15px;
    color: #000;
    line-height: 1.1;
  }

  .product-title { 
    font-size: 18px; 
    font-family: 'Poppins', sans-serif;
    margin-bottom: 25px; 
    color: #333; 
  }

  .price-section { margin-bottom: 30px; }
  .main-price { font-size: 42px; color: #ff914d; font-weight: 700; }
  .sub-price { font-size: 14px; color: #777; margin-left: 10px; }

  .action-row { display: flex; gap: 15px; flex-wrap: wrap; }

  /* Quantity & Button */
  .quantity-selector {
    display: flex;
    align-items: center;
    background: #ffffff;
    border-radius: 50px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    border: 1px solid #eee;
    padding: 0 10px;
  }

  .qty-btn {
    background: none; border: none; width: 35px; height: 45px;
    font-size: 20px; cursor: pointer; color: #ff914d;
  }

  .qty-input {
    width: 40px; border: none; text-align: center;
    font-weight: 700; font-size: 16px;
  }

  .add-to-cart-btn {
    background-color: #ff914d;
    color: white;
    padding: 10px 20px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 16px;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    flex-grow: 1;
    max-width: 200px;
  }
  
  .add-to-cart-btn:hover { 
    background-color: #000;
    color: #ff914d;
    transform: translateY(-2px);
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .step-into-banner { padding: 80px 20px 40px; text-align: center; }
    .top-logo-text { width: 100%; left: 0; top: 30px; }
    .banner-container { gap: 20px; }
    .banner-content-col { text-align: center; }
    .action-row { justify-content: center; }
    .diagonal-bg { clip-path: polygon(0 10%, 100% 0%, 100% 100%, 0 100%); }
    .guide-img { width: 220px; height: 240px; } /* Slightly smaller for mobile */
  }

  @media (min-width: 1400px) {
    .banner-container { max-width: 1300px; }
  }
</style>