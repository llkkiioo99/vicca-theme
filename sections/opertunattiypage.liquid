{% schema %}
{
  "name": "Honesty Message Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FDF9F3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (Orange) Color",
      "default": "#FF8A5B"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sé honesto/a."
    },
    {
      "type": "textarea",
      "id": "main_text",
      "label": "Main Text",
      "default": "La transparencia es clave \nprimero contigo mismo/a, \ndespués con nosotros."
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Honesty Message Section"
    }
  ]
}
{% endschema %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');

  .honesty-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px 20px;
    text-align: center;
    font-family: 'Inter', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
  }

  .honesty-container {
    /* Quitamos el max-width restrictivo para que los saltos manuales manden */
    max-width: 600px; 
    margin: 0 auto;
  }

  .honesty-accent-text {
    color: {{ section.settings.accent_color }};
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 15px;
    display: block;
    letter-spacing: -0.01em;
  }

  .honesty-main-description {
    color: #1a1a1a;
    font-size: 28px;
    font-weight: 400;
    line-height: 1.4; /* Un poco más de espacio para que las 3 líneas respiren */
    margin: 0;
    letter-spacing: -0.02em;
  }

  /* Responsivo para móviles */
  @media screen and (max-width: 768px) {
    .honesty-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.6 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 }}px;
    }
    .honesty-accent-text {
      font-size: 18px;
    }
    .honesty-main-description {
      font-size: 20px;
      line-height: 1.3;
    }
  }
</style>

<section class="honesty-section-{{ section.id }}">
  <div class="honesty-container">
    <span class="honesty-accent-text">{{ section.settings.heading }}</span>
    <p class="honesty-main-description">
      {% comment %} 
        El filtro newline_to_br convierte tus 'Enters' del editor en etiquetas <br> 
      {% endcomment %}
      {{ section.settings.main_text | newline_to_br }}
    </p>
  </div>
</section>