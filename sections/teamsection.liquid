{%- style -%}
  /* Import Poppins Font */
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mb }}px;
    padding-bottom: {{ section.settings.padding_bottom_mb }}px;
    background-color: {{ section.settings.bg_color }};
    position: relative;
    overflow: hidden;
    font-family: 'Poppins', sans-serif; /* Apply to whole section */
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .team-section-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  /* Headline Style - Bold and Black */
  .team-header h2 {
    font-size: 36px;
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
    margin-bottom: 25px;
    color: #000000; 
    letter-spacing: -1px;
    line-height: 1.2;
  }

  .team-header-description {
    font-size: 16px;
    color: #333333;
    max-width: 850px;
    margin: 0 auto 60px;
    line-height: 1.6;
    font-weight: 400;
  }

  .team-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 40px;
  }

  /* Card Styling */
  .team-card {
    background: #ffffff;
    border-radius: 80px; 
    padding: 60px 40px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.04);
    flex: 1 1 100%;
    max-width: 460px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  @media screen and (min-width: 768px) {
    .team-card {
      flex: 0 1 calc(50% - 40px);
    }
  }

  /* Image Container & Visual Enhancement */
  .team-image-container {
    width: 220px;
    height: 280px;
    margin-bottom: 30px;
    overflow: hidden;
    border-radius: 110px;
    background-color: #f9f9f9;
  }

  .team-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Visual Enhancement: Brightness and slight Contrast */
    filter: brightness(1.05) contrast(1.02) saturate(1.05);
    transition: transform 0.3s ease;
  }

  .team-card:hover .team-image {
    transform: scale(1.03);
  }

  .team-info h3 {
    margin: 0 0 5px;
    font-size: 28px;
    font-weight: 700;
    color: #000000;
  }

  .team-info .role {
    font-size: 16px;
    color: #666666;
    font-weight: 500;
    margin-bottom: 25px;
    display: block;
  }

  .team-info .description {
    font-size: 15px;
    color: #444444;
    line-height: 1.7;
    text-align: center;
    font-weight: 400;
  }

  .team-info .description p { margin: 0; }

  .bg-waves {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    opacity: 0.3;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="bg-waves">
    <svg viewBox="0 0 1440 320" xmlns="http://www.w3.org/2000/svg" style="position: absolute; bottom: 0; width: 100%;">
      <path fill="#d1d1d1" fill-opacity="0.2" d="M0,224L60,202.7C120,181,240,139,360,138.7C480,139,600,181,720,208C840,235,960,245,1080,229.3C1200,213,1320,171,1380,149.3L1440,128L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"></path>
    </svg>
  </div>

  <div class="team-section-wrapper">
    <div class="team-header">
      <h2>{{ section.settings.heading }}</h2>
      <div class="team-header-description">{{ section.settings.subheading }}</div>
    </div>

    <div class="team-grid">
      {% for block in section.blocks %}
        <div class="team-card" {{ block.shopify_attributes }}>
          <div class="team-image-container">
            {% if block.settings.image != blank %}
              <img 
                src="{{ block.settings.image | img_url: '800x1000', crop: 'center' }}" 
                alt="{{ block.settings.name }}" 
                class="team-image"
                loading="lazy"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'team-image' }}
            {% endif %}
          </div>
          
          <div class="team-info">
            <h3>{{ block.settings.name }}</h3>
            <span class="role">{{ block.settings.role }}</span>
            <div class="description">{{ block.settings.bio }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Team Vicca Style",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfaf5"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Una gran historia empieza con un gran equipo"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "<p>Todo lo que hacemos en <strong>vicca.</strong> nace de la confianza y la experiencia compartida.</p>"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mb",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mb",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "team_member",
      "name": "Team Member",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Member Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Victor Carbó"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role/Position",
          "default": "CEO y fundador"
        },
        {
          "type": "richtext",
          "id": "bio",
          "label": "Bio/Description",
          "default": "<p>Escribe aquí la descripción de la persona...</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Vicca Style",
      "blocks": [
        { "type": "team_member" },
        { "type": "team_member" }
      ]
    }
  ]
}
{% endschema %}