{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@700&display=swap');

  .hero-section-{{ section.id }} {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    background-size: cover;
    background-position: center;
    box-sizing: border-box;
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | img_url: '1800x' }}');
    {% else %}
      background-color: {{ section.settings.bg_color }};
    {% endif %}
  }

  .hero-text-{{ section.id }} {
    font-family: 'Poppins', sans-serif !important;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin: 0 auto;
    line-height: 1.2;
    word-wrap: break-word;
    overflow-wrap: break-word;
    /* Desktop default behavior */
    white-space: normal; 
    max-width: 100%;
  }

  .hero-text-{{ section.id }} span.dot {
    color: #FF7A00;
  }

  /* --- Responsividad Dinámica --- */

  /* Desktop & Laptops Grandes */
  @media screen and (min-width: 1200px) {
    .hero-section-{{ section.id }} {
      padding: {{ section.settings.padding_top_desktop }}px 0 {{ section.settings.padding_bottom_desktop }}px;
    }
    .hero-text-{{ section.id }} { 
      font-size: {{ section.settings.font_size_desktop }}px;
      white-space: nowrap; /* Mantiene una sola línea en pantallas grandes */
    }
  }

  /* Tablets y Laptops Pequeñas (Ajuste fluido) */
  @media screen and (max-width: 1199px) and (min-width: 768px) {
    .hero-section-{{ section.id }} {
      padding: 80px 20px;
    }
    .hero-text-{{ section.id }} { 
      /* Escala el texto entre 30px y el tamaño de desktop según el ancho de pantalla */
      font-size: clamp(30px, 5vw, {{ section.settings.font_size_desktop }}px);
      white-space: normal; 
    }
  }

  /* Móviles */
  @media screen and (max-width: 767px) {
    .hero-section-{{ section.id }} {
      padding: {{ section.settings.padding_top_mobile }}px 15px {{ section.settings.padding_bottom_mobile }}px;
    }
    .hero-text-{{ section.id }} { 
      font-size: {{ section.settings.font_size_mobile }}px;
      white-space: normal; /* Permite que el texto baje si es muy largo para el celular */
      display: block;
      width: 100%;
    }
  }
{% endstyle %}

<section class="hero-section-{{ section.id }}">
  <div class="page-width" style="width: 100%;">
    <h2 class="hero-text-{{ section.id }}">
      {%- assign heading = section.settings.heading_text -%}
      {%- if heading contains '.' -%}
        {{ heading | replace: '.', '<span class="dot">.</span>' }}
      {%- else -%}
        {{ heading }}
      {%- endif -%}
    </h2>
  </div>
</section>

{% schema %}
{
  "name": "Custom Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "Descubre cómo vicca. te puede ayudar"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f7f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Desktop Settings"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Font Size (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Section Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Section Padding Bottom",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile Settings"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 14,
      "max": 60,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Mobile)",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Section Padding Top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Section Padding Bottom",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Banner"
    }
  ]
}
{% endschema %}