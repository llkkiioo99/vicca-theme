{% schema %}
{
  "name": "Vicca Affiliate Banner",
  "settings": [
    { "type": "text", "id": "heading_thin", "label": "Heading (Serif)", "default": "Programa de" },
    { "type": "text", "id": "heading_bold", "label": "Heading (Bold)", "default": "afiliados" },
    { "type": "url", "id": "link_join", "label": "Link: Quiero afiliarme (fallback)" },
    { "type": "url", "id": "link_login", "label": "Link: Ya soy vicca.afiliate (fallback)" }
  ],
  "presets": [{ "name": "Vicca Affiliate Banner" }]
}
{% endschema %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:wght@300;400;500;600;700&display=swap');

  .vicca-banner-section {
    background-color: #FBF7F0;
    padding: 60px 5%;
    font-family: 'Poppins', sans-serif;
  }

  .vicca-am-container { max-width: 1100px; margin: 0 auto 50px auto; display: flex; align-items: center; justify-content: space-between; gap: 50px; }

  .vicca-title-box { flex: 1; text-align: left; }
  .vicca-title-box h1 { margin: 0; line-height: 0.9; color: #000; }

  .vicca-title-box span.thin {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 5vw, 50px);
    display: block;
    font-weight: 400;
  }

  .vicca-title-box span.bold {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(48px, 6vw, 68px);
    font-weight: 700;
    display: block;
    letter-spacing: -2px;
  }

  .vicca-content-box { flex: 1; font-size: 16px; line-height: 1.5; color: #000; text-align: left; max-width: 450px; font-weight: 400; }
  .vicca-content-box .dot-orange { color: #FF9654; font-weight: 800; }
  .vicca-content-box .bold-text { font-weight: 700; }
  .vicca-content-box .underline-text { text-decoration: underline; text-decoration-thickness: 2px; }

  .vicca-button-wrapper { display: flex; justify-content: center; margin-bottom: 50px; }
  .btn-group { display: inline-flex; background-color: #000; border-radius: 50px; overflow: hidden; padding: 0; }

  .vicca-btn {
    text-decoration: none; padding: 16px 32px; font-weight: 600; font-size: 15px;
    cursor: pointer; border: none; color: #FFF; transition: 0.3s; background: none; font-family: 'Poppins', sans-serif;
    display: inline-block;
  }
  .vicca-btn.btn-orange { background-color: #FF9654; border-radius: 50px; color: #fff; }
  .vicca-btn.btn-black { background-color: #000; color: #FFF; }

  @media (max-width: 768px) {
    .vicca-am-container { flex-direction: column; text-align: center; }
    .vicca-title-box { text-align: center; }
    .vicca-content-box { text-align: center; max-width: 100%; }
    .btn-group { flex-direction: column; width: 100%; border-radius: 20px; }
    .vicca-btn { padding: 14px 24px; font-size: 14px; }
  }
</style>

<section class="vicca-banner-section">
  <div class="vicca-am-container">
    <div class="vicca-title-box">
      <h1>
        <span class="thin">{{ section.settings.heading_thin }}</span>
        <span class="bold">{{ section.settings.heading_bold }}</span>
      </h1>
    </div>

    <div class="vicca-content-box">
      Conviértete en un <span class="bold-text">vicca<span class="dot-orange">.</span>afiliate</span> y ayuda a personas a empezar una nueva vida en Holanda con nuestro programa <span class="underline-text">ganando dinero por ello.</span>
    </div>
  </div>

  <div class="vicca-button-wrapper">
    <div class="btn-group">
      <a href="javascript:void(0)" class="vicca-btn btn-orange" onclick="viccaOpenSignupModal()">Quiero afiliarme</a>
      <a href="javascript:void(0)" class="vicca-btn btn-black" onclick="viccaOpenAffiliateModal()">Ya soy vicca.afiliate</a>
    </div>
  </div>
</section>