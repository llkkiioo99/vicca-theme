{%- style -%}
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Poppins:wght@700;800;900&display=swap');

.agency-hero-{{ section.id }} {
  background-color: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  text-align: center;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

/* Container */
.hero-title-container {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  max-width: 1100px;
  margin: -20px auto 0;
  position: relative;
  padding: 0 20px;
}

.text-block {
  display: flex;
  flex-direction: column;
  z-index: 2;
  flex: 1;
}

.text-block.left {
  text-align: right;
  margin-right: -3vw;
}

.text-block.right {
  text-align: left;
  margin-left: -3vw;
}

.serif-text {
  font-family: 'Playfair Display', serif;
  font-size: clamp(16px, 3.5vw, 48px);
  color: #000;
  letter-spacing: -0.5px;
  line-height: 1.1;
}

.bold-text {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: clamp(20px, 4.5vw, 52px);
  color: #000;
  letter-spacing: -1px;
  line-height: 0.85;
  margin-top: 2px;
}

.bg-text-italic {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(30px, 8vw, 100px);
  color: #000;
  opacity: 0.08;
  line-height: 1;
  user-select: none;
  z-index: 1;
  pointer-events: none;
  flex-shrink: 0;
  position: relative;
  margin: 0 5px;
}

.desc-box {
  margin: 40px auto 0;
  max-width: 550px;
  font-family: 'Poppins', sans-serif;
  font-size: clamp(13px, 1.2vw, 15px);
  color: #444;
  line-height: 1.6;
  padding: 0 20px;
}

.hero-btns {
  margin-top: 30px;
}

.hero-btn {
  background: #ff914d;
  color: #fff;
  padding: 18px 48px 18px 52px;
  border-radius: 60px;
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  text-decoration: none;
  font-size: 17px;
  display: inline-flex;
  align-items: center;
  gap: 16px;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  border: none;
  letter-spacing: 0.2px;
  cursor: pointer;
}

.hero-btn::after {
  content: '→';
  font-size: 20px;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.hero-btn:hover {
  background: #222;
  color: #ff914d;
  transform: translateY(-3px);
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
}

.hero-btn:hover::after {
  transform: translateX(4px);
}

@media (max-width: 1024px) {
  .agency-hero-{{ section.id }} {
    padding-top: 60px;
    padding-bottom: 50px;
  }
  .desc-box { margin-top: 30px; }
}

@media (max-width: 768px) {
  .agency-hero-{{ section.id }} {
    padding-top: 40px;
    padding-bottom: 36px;
  }
  .hero-title-container {
    margin-top: 0;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }
  .text-block { text-align: center !important; }
  .text-block.left { margin-right: 0; }
  .text-block.right { margin-left: 0; }
  .bg-text-italic { display: none; }
  .desc-box { margin-top: 24px; max-width: 100%; font-size: 14px; }
  .hero-btn { padding: 16px 36px 16px 40px; font-size: 15px; }
}

@media (max-width: 480px) {
  .agency-hero-{{ section.id }} {
    padding-top: 30px;
    padding-bottom: 28px;
  }
  .hero-title-container { padding: 0 16px; }
  .desc-box { font-size: 13px; padding: 0 16px; }
  .hero-btn { padding: 14px 32px 14px 36px; font-size: 14px; }
  .hero-btns { margin-top: 20px; }
}
{%- endstyle -%}

<section class="agency-hero-{{ section.id }}">
  <div class="hero-title-container">
    <div class="text-block left">
      <span class="serif-text">{{ section.settings.text_1 }}</span>
      <span class="bold-text">{{ section.settings.text_3 }}</span>
    </div>

    <div class="bg-text-italic">
      {{ section.settings.bg_text }}
    </div>

    <div class="text-block right">
      <span class="serif-text">{{ section.settings.text_2 }}</span>
      <span class="bold-text">{{ section.settings.text_4 }}</span>
    </div>
  </div>

  <div class="desc-box">
    {{ section.settings.desc_text }}
  </div>

  <div class="hero-btns">
    {% if section.settings.btn_label != blank %}
      <a href="{{ section.settings.btn_link }}" class="hero-btn">
        {{ section.settings.btn_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Agency Custom Hero",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FAF7F2" },
    { "type": "color", "id": "accent_color", "label": "Button Background", "default": "#FF9D5C" },
    { "type": "color", "id": "btn_hover_bg", "label": "Button Hover Background", "default": "#000000" },
    { "type": "color", "id": "btn_hover_text", "label": "Button Hover Text", "default": "#FFFFFF" },
    { "type": "text", "id": "bg_text", "label": "Background Italic Text", "default": "como" },
    { "type": "text", "id": "text_1", "label": "Serif Text Left", "default": "Cercanos" },
    { "type": "text", "id": "text_2", "label": "Serif Text Right", "default": "amigos," },
    { "type": "text", "id": "text_3", "label": "Bold Text Left", "default": "expertos" },
    { "type": "text", "id": "text_4", "label": "Bold Text Right", "default": "agencia" },
    { "type": "textarea", "id": "desc_text", "label": "Description", "default": "Transformamos el reto de mudarte a Holanda en una experiencia guiada..." },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Empezar" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Agency Custom Hero"
    }
  ]
}
{% endschema %}