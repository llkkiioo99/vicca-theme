{%- style -%}
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Poppins:wght@700;800;900&display=swap');

.agency-hero-{{ section.id }} {
  background-color: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  text-align: center;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

/* Container: Moved up using negative margin */
.hero-title-container {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  max-width: 1200px;
  margin: -40px auto 0; /* Changed from 0 to -40px to move headline/photos up */
  position: relative;
  padding: 0 10px;
  white-space: nowrap;
}

.text-block {
  display: flex;
  flex-direction: column;
  z-index: 2;
  flex: 1;
}

.text-block.left {
  text-align: right;
  margin-right: -3vw;
}

.text-block.right {
  text-align: left;
  margin-left: -3vw;
}

.serif-text {
  font-family: 'Playfair Display', serif;
  font-size: clamp(18px, 4.5vw, 70px); 
  color: #000;
  letter-spacing: -0.5px;
  line-height: 1.1;
}

.bold-text {
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  font-size: clamp(22px, 6.5vw, 70px);
  color: #000;
  letter-spacing: -1px;
  line-height: 0.85;
  margin-top: 2px;
}

.bg-text-italic {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-weight: 400;
  font-size: clamp(35px, 11vw, 140px);
  color: #000;
  opacity: 0.08;
  line-height: 1;
  user-select: none;
  z-index: 1;
  pointer-events: none;
  flex-shrink: 0;
  position: relative;
  margin: 0 5px;
}

/* Description box: Smaller text and more space above */
.desc-box {
  margin: 60px auto 0; /* Increased from 40px to 60px to move it down */
  max-width: 600px; /* Narrowed slightly for better readability at smaller size */
  font-family: 'Poppins', sans-serif;
  font-size: clamp(12px, 1.5vw, 15px); /* Decreased size (was 14px-18px) */
  color: #444;
  line-height: 1.6;
  padding: 0 20px;
}

.hero-btns {
  margin-top: 30px;
}

.hero-btn {
  background: {{ section.settings.accent_color }};
  color: #fff;
  padding: 12px 40px;
  border-radius: 50px;
  font-family: 'Poppins', sans-serif;
  font-weight: 700;
  text-decoration: none;
  font-size: 16px;
  display: inline-block;
  transition: all 0.3s ease;
  border: 2px solid transparent;
}

.hero-btn:hover {
  background-color: {{ section.settings.btn_hover_bg }};
  color: {{ section.settings.btn_hover_text }};
  border-color: {{ section.settings.btn_hover_bg }};
}

@media (max-width: 768px) {
  .agency-hero-{{ section.id }} {
    padding-top: 40px;
    padding-bottom: 40px;
  }
  .hero-title-container { margin-top: -20px; } /* Adjusting the "move up" for mobile */
  .text-block.left { margin-right: -4vw; }
  .text-block.right { margin-left: -4vw; }
}
{%- endstyle -%}

<section class="agency-hero-{{ section.id }}">
  <div class="hero-title-container">
    <div class="text-block left">
      <span class="serif-text">{{ section.settings.text_1 }}</span>
      <span class="bold-text">{{ section.settings.text_3 }}</span>
    </div>

    <div class="bg-text-italic">
      {{ section.settings.bg_text }}
    </div>

    <div class="text-block right">
      <span class="serif-text">{{ section.settings.text_2 }}</span>
      <span class="bold-text">{{ section.settings.text_4 }}</span>
    </div>
  </div>

  <div class="desc-box">
    {{ section.settings.desc_text }}
  </div>

  <div class="hero-btns">
    {% if section.settings.btn_label != blank %}
      <a href="{{ section.settings.btn_link }}" class="hero-btn">
        {{ section.settings.btn_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Agency Custom Hero",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FAF7F2" },
    { "type": "color", "id": "accent_color", "label": "Button Background", "default": "#FF9D5C" },
    { "type": "color", "id": "btn_hover_bg", "label": "Button Hover Background", "default": "#000000" },
    { "type": "color", "id": "btn_hover_text", "label": "Button Hover Text", "default": "#FFFFFF" },
    { "type": "text", "id": "bg_text", "label": "Background Italic Text", "default": "como" },
    { "type": "text", "id": "text_1", "label": "Serif Text Left", "default": "Cercanos" },
    { "type": "text", "id": "text_2", "label": "Serif Text Right", "default": "amigos," },
    { "type": "text", "id": "text_3", "label": "Bold Text Left", "default": "expertos" },
    { "type": "text", "id": "text_4", "label": "Bold Text Right", "default": "agencia" },
    { "type": "textarea", "id": "desc_text", "label": "Description", "default": "Transformamos el reto de mudarte a Holanda en una experiencia guiada..." },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "Empezar" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Agency Custom Hero"
    }
  ]
}
{% endschema %}