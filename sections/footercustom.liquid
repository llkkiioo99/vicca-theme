            <img src="{{ section.settings.top_logo | img_url: 'large' }}" alt="{{ shop.name }}">
          {% else %}
            <span style="font-weight:800; font-size:24px; color:#ffffff;">vicca.agency</span>
          {% endif %}
        </a>
      </div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
      <a href="{{ section.settings.btn_url | default: '#' }}" class="v-btn">{{ section.settings.btn_text }}</a>
    </div>

    <div class="v-links-area">
      <div class="v-link-col">
        <h4>{{ section.settings.menu_title_1 }}</h4>
