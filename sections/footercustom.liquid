{% schema %}
{
  "name": "Vicca Responsive Footer",
  "settings": [
    {
      "type": "header",
      "content": "Logos"
    },
    {
      "type": "image_picker",
      "id": "top_logo",
      "label": "Top Logo"
    },
    {
      "type": "image_picker",
      "id": "bottom_logo",
      "label": "Bottom Tagline Logo"
    },
    {
      "type": "header",
      "content": "Main Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hazlo bien desde el principio."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Cuéntanos tu caso y sal de esta sesión con claridad, estrategia y próximos pasos definidos."
    },
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Agendar orientación sin compromiso"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background Color",
      "default": "#f18d4d"
    },
    {
      "type": "color",
      "id": "btn_txt_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Navigation Menus"
    },
    {
      "type": "text",
      "id": "menu_title_1",
      "label": "Menu 1 Title",
      "default": "Servicios"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu 1 (Links)"
    },
    {
      "type": "text",
      "id": "menu_title_2",
      "label": "Menu 2 Title",
      "default": "Empresa"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu 2 (Links)"
    },
    {
      "type": "text",
      "id": "menu_title_3",
      "label": "Menu 3 Title",
      "default": "Soporte"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu 3 (Links)"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Legal Menu (Bottom)"
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "fb_link",
      "label": "Facebook Link"
    },
    {
      "type": "url",
      "id": "ig_link",
      "label": "Instagram Link"
    },
    {
      "type": "url",
      "id": "tiktok_link",
      "label": "TikTok Link"
    },
    {
      "type": "url",
      "id": "x_link",
      "label": "X (Twitter) Link"
    },
    {
      "type": "url",
      "id": "wa_link",
      "label": "WhatsApp Link"
    }
  ],
  "presets": [
    {
      "name": "Vicca Responsive Footer"
    }
  ]
}
{% endschema %}

{% comment %} <style>
  /* Importar Poppins */
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

  .v-footer {
    background-color: #1a1a1a;
    color: #ffffff;
    padding: 80px 5%;
    font-family: 'Poppins', sans-serif !important;
    overflow: hidden;
  }
  
  .v-footer-top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 50px;
  }
  
  .v-brand-area {
    flex: 1;
    min-width: 280px;
    max-width: 450px;
  }
  
  .v-footer-logo a {
    text-decoration: none;
    display: inline-block;
  }

  .v-footer-logo img {
    max-width: 180px;
    height: auto;
    display: block;
  }
  
  .v-brand-area h2 {
    font-family: 'Poppins', sans-serif;
    color: #ffffff;
    font-size: clamp(26px, 4vw, 42px);
    font-weight: 800;
    margin: 25px 0;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }
  
  .v-brand-area p {
    font-family: 'Poppins', sans-serif;
    color: #ffffff;
    font-size: 16px;
    opacity: 1;
    margin-bottom: 35px;
    line-height: 1.5;
  }
  
  .v-btn {
    font-family: 'Poppins', sans-serif;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_txt_color }};
    padding: 16px 32px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 700;
    display: inline-block;
    transition: all 0.3s ease;
    border: 2px solid {{ section.settings.btn_bg }};
    text-align: center;
  }
  
  .v-btn:hover { 
    background-color: #000000;
    color: #ff9d54;
    border-color: #000000;
  }

  .v-links-area {
    flex: 2;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    min-width: 300px;
  }
  
  .v-link-col h4 {
    font-family: 'Poppins', sans-serif;
    color: #ffffff;
    font-size: 18px;
    margin-bottom: 25px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  .v-link-col ul { list-style: none; padding: 0; margin: 0; }
  .v-link-col ul li { margin-bottom: 14px; }
  .v-link-col ul li a { 
    font-family: 'Poppins', sans-serif;
    color: #ffffff; 
    text-decoration: none; 
    font-size: 15px;
    transition: opacity 0.3s;
    opacity: 0.9;
  }
  
  .v-link-col ul li a:hover { opacity: 1; text-decoration: underline; }
  
  .v-contact-info {
    font-family: 'Poppins', sans-serif;
    margin-top: 20px;
    font-size: 14px;
    line-height: 1.6;
    color: #ffffff;
  }

  .v-footer-mid {
    margin-top: 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.2);
    padding-bottom: 40px;
    flex-wrap: wrap;
    gap: 30px;
  }
  
  .v-tagline-logo a { text-decoration: none; }
  .v-tagline-logo img { max-width: 250px; height: auto; display: block; }
  
  .v-tagline-text {
    font-family: 'Poppins', sans-serif;
    font-size: 20px;
    color: #ffffff;
  }

  .v-socials { display: flex; gap: 20px; }
  
  .v-socials a svg { 
    width: 28px; 
    height: 28px; 
    fill: {{ section.settings.btn_bg }}; 
    transition: all 0.3s ease; 
  }
  
  .v-socials a:hover svg { 
    transform: translateY(-5px); 
    filter: brightness(1.2); 
  }

  .v-footer-bottom {
    font-family: 'Poppins', sans-serif;
    margin-top: 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: #ffffff;
    flex-wrap: wrap;
    gap: 20px;
  }
  
  .v-legal-links { display: flex; flex-wrap: wrap; gap: 20px; }
  .v-legal-links a { font-family: 'Poppins', sans-serif; color: #ffffff; text-decoration: none; }
  .v-legal-links a:hover { text-decoration: underline; }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .v-links-area { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 767px) {
    .v-footer { padding: 50px 20px; text-align: center; }
    .v-links-area { grid-template-columns: 1fr; }
    .v-footer-mid { flex-direction: column; }
    .v-footer-bottom { flex-direction: column-reverse; }
    .v-btn { width: 100%; }
    .v-socials { justify-content: center; }
  }
</style>

<footer class="v-footer">
  <div class="v-footer-top">
    <div class="v-brand-area">
      <div class="v-footer-logo">
        <a href="{{ routes.root_url }}">
          {% if section.settings.top_logo != blank %}
            <img src="{{ section.settings.top_logo | img_url: 'medium' }}" alt="{{ shop.name }}">
          {% else %}
            <span style="font-weight:800; font-size:24px; color:#ffffff;">vicca.agency</span>
          {% endif %}
        </a>
      </div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
      <a href="{{ section.settings.btn_url | default: '#' }}" class="v-btn">{{ section.settings.btn_text }}</a>
    </div>

    <div class="v-links-area">
      <div class="v-link-col">
        <h4>{{ section.settings.menu_title_1 }}</h4>
        <ul>
          {% for link in linklists[section.settings.menu_1].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div class="v-link-col">
        <h4>{{ section.settings.menu_title_2 }}</h4>
        <ul>
          {% for link in linklists[section.settings.menu_2].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div class="v-link-col">
        <h4>{{ section.settings.menu_title_3 }}</h4>
        <ul>
          {% for link in linklists[section.settings.menu_3].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
        <div class="v-contact-info">
          contact@vicca-agency.com<br>
          WhatsApp: +31 612 345 678
        </div>
      </div>
    </div>
  </div>

  <div class="v-footer-mid">
    <div class="v-tagline-logo">
      <a href="{{ routes.root_url }}">
        {% if section.settings.bottom_logo != blank %}
          <img src="{{ section.settings.bottom_logo | img_url: 'large' }}" alt="Tagline Logo">
        {% else %}
          <div class="v-tagline-text">Cercanos <span style="font-style:italic; opacity:0.7;">como</span> amigos,<br><strong>expertos agencia</strong></div>
        {% endif %}
      </a>
    </div>
    
    <div class="v-socials">
