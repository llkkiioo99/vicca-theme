{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');

  .vicca-guide-wrapper {
    font-family: 'Poppins', sans-serif;
    color: #000;
    -webkit-font-smoothing: antialiased;
  }

  .vicca-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .vicca-header {
    text-align: center;
    max-width: 900px;
    margin: 0 auto 80px;
  }

  .vicca-header h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 28px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
    letter-spacing: -0.5px;
  }

  /* Estilos para la marca y el punto naranja */
  .vicca-header .brand { 
    font-weight: 700; 
    color: #000; 
  }
  
  .vicca-header .brand-dot { 
    color: #f08143; 
  }

  .vicca-header .highlight { 
    color: #f08143; 
    font-weight: 600; 
  }

  .vicca-grid {
    display: flex;
    align-items: center;
    gap: 80px;
  }

  .vicca-text-side { 
    flex: 1.2; 
  }
  
  .vicca-image-side { 
    flex: 1; 
  }

  .vicca-text-side p {
    font-family: 'Poppins', sans-serif;
    font-size: 18px;
    line-height: 1.6;
    font-weight: 400;
    color: #000;
    margin-bottom: 25px;
  }

  .vicca-text-side p:last-child {
    font-size: 16px;
    margin-bottom: 0;
  }

  .vicca-text-side strong {
    font-weight: 700;
  }

  .image-box {
    border-radius: 40px;
    overflow: hidden;
    line-height: 0;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .image-box img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 991px) {
    .vicca-header h2 { font-size: 22px; }
    .vicca-grid { 
      flex-direction: column; 
      gap: 40px; 
      text-align: center;
    }
    .vicca-container { padding: 0 20px; }
    .image-box { border-radius: 25px; }
  }
</style>

<section class="vicca-guide-wrapper section-{{ section.id }}-padding">
  <div class="vicca-container">
    <div class="vicca-header">
      <h2>
        En <span class="brand">vicca<span class="brand-dot">.</span></span> ponemos a tu disposición nuestra 
        <span class="highlight">guía práctica digital</span>, creada para acompañarte en cada paso de tu mudanza a los Países Bajos.
      </h2>
    </div>

    <div class="vicca-grid">
      <div class="vicca-text-side">
        <p>
          Esta guía es un recurso pensado para que tengas <strong>en un solo lugar toda la información que necesitas.</strong>
        </p>
        <p>
          Aquí encontrarás explicados paso a paso los trámites burocráticos esenciales (BSN, cuenta bancaria, seguro médico, registro en vivienda...), mejores webs y aplicaciones para encontrar piso o trabajo, cómo evitar sanciones comunes, las mejores opciones de transporte, supermercados donde ahorrar, e incluso tips reales que solo conoces viviendo en el país (sí, hasta cómo funciona la basura o dónde comprar muebles baratos).
        </p>
      </div>

      <div class="vicca-image-side">
        <div class="image-box">
          {% if section.settings.image != blank %}
            <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy">
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Vicca Guide Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de la sección"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Color de Fondo",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Espaciado (Padding)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Superior",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Vicca Guide Section"
    }
  ]
}
{% endschema %}