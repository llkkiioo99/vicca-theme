{% schema %}
{
  "name": "Vicca Booking Section",
  "settings": [
    {
      "type": "text",
      "id": "top_tagline",
      "label": "Top Tagline",
      "default": "Step Into"
    },
    {
      "type": "text",
      "id": "top_tagline_bold",
      "label": "Top Tagline Bold",
      "default": "Opportunity"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "¿Listo/a para dar el primer paso?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Agenda una llamada con el equipo de vicca"
    },
    {
      "type": "textarea",
      "id": "description_1",
      "label": "Description Paragraph 1",
      "default": "Conocerás en qué consiste el programa, cómo podemos ayudarte paso a paso y si realmente se adapta a lo que necesitas."
    },
    {
      "type": "textarea",
      "id": "description_2",
      "label": "Description Paragraph 2",
      "default": "Queremos que tomes decisiones con claridad, esta es tu oportunidad. Resuelve tus dudas y descubre si este programa es para ti."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfaf5"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "custom_liquid",
      "name": "Custom Liquid/HTML",
      "settings": [
        {
          "type": "liquid",
          "id": "liquid_code",
          "label": "Liquid/HTML Code",
          "default": "<p>Escribe aquí o inserta una app</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vicca Booking Section",
      "blocks": [
        {
          "type": "custom_liquid"
        }
      ]
    }
  ]
}
{% endschema %}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<section class="vicca-booking-wrapper">
  <div class="vicca-top-bg">
     <div class="vicca-container">
        <div class="vicca-tagline-area">
          <p class="vicca-tagline">{{ section.settings.top_tagline }}</p>
          <h1 class="vicca-tagline-bold">{{ section.settings.top_tagline_bold }}</h1>
        </div>
     </div>
  </div>

  <div class="vicca-main-section" style="background-color: {{ section.settings.bg_color }};">
    <div class="vicca-container">
      <div class="vicca-flex-layout">
        
        <div class="vicca-content">
          <h2 class="vicca-h2">{{ section.settings.heading }}</h2>
          <h3 class="vicca-h3">{{ section.settings.subheading }}<span class="dot">.</span></h3>
          
          <div class="vicca-desc">
            <p>{{ section.settings.description_1 }}</p>
            <p>{{ section.settings.description_2 }}</p>
          </div>

          <ul class="vicca-list">
            <li><span class="check-icon">✓</span> Acompañamiento personalizado.</li>
            <li><span class="check-icon">✓</span> Decide con claridad.</li>
            <li><span class="check-icon">✓</span> Reunión vía Google Meet sin compromiso.</li>
          </ul>
        </div>

        <div class="vicca-calendar-wrapper">
          <div class="vicca-card">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '@app' -%}
                  {% render block %}
                {%- when 'custom_liquid' -%}
                  {{ block.settings.liquid_code }}
              {%- endcase -%}
            {%- endfor -%}
            
            {% if section.blocks.size == 0 %}
              <div class="vicca-placeholder">
                <p>Haz clic en "Agregar bloque" para insertar una App o código de calendario.</p>
              </div>
            {% endif %}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .vicca-booking-wrapper {
    position: relative;
    overflow: hidden;
    font-family: 'Poppins', sans-serif;
  }

  .vicca-top-bg {
    background: #ffffff;
    padding: 100px 0 150px 0;
    margin-bottom: -100px; 
    clip-path: polygon(0 0, 100% 0, 100% 70%, 0 100%);
  }

  .vicca-main-section {
    padding: 100px 0 120px 0;
  }

  .vicca-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .vicca-flex-layout {
    display: flex;
    align-items: flex-start;
    gap: 80px;
  }

  .vicca-tagline-area { margin-bottom: 20px; }
  
  .vicca-tagline { 
    font-family: 'Playfair Display', serif; 
    font-size: 36px; 
    font-weight: 400; 
    margin: 0; 
    line-height: 1.2; 
    color: #000;
  }
  
  .vicca-tagline-bold { 
    font-family: 'Poppins', sans-serif;
    font-size: 52px; 
    font-weight: 800; 
    margin: 0; 
    line-height: 1; 
    color: #000; 
  }

  .vicca-content { flex: 1.2; }
  .vicca-calendar-wrapper { flex: 1; }

  .vicca-h2 { 
    font-family: 'Poppins', sans-serif;
    font-size: 64px; 
    font-weight: 900; 
    line-height: 1.1; 
    margin-bottom: 30px; 
    color: #000; 
    letter-spacing: -1.5px;
  }
  
  .vicca-h3 { 
    font-family: 'Poppins', sans-serif;
    font-size: 26px; 
    font-weight: 700; 
    margin-bottom: 25px; 
    color: #000; 
  }
  
  .dot { color: #f28132; }

  .vicca-desc p { 
    font-family: 'Poppins', sans-serif;
    font-size: 18px; 
    color: #555; 
    line-height: 1.6; 
    margin-bottom: 20px; 
    max-width: 520px;
  }

  .vicca-list { list-style: none; padding: 0; margin-top: 40px; }
  .vicca-list li { 
    display: flex; 
    align-items: center; 
    font-family: 'Poppins', sans-serif;
    font-weight: 700; 
    margin-bottom: 15px; 
    font-size: 18px; 
    color: #000;
  }

  .check-icon {
    background: #f28132;
    color: white;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-right: 15px;
    font-size: 12px;
    flex-shrink: 0;
  }

  .vicca-card {
    background: #ffffff;
    width: 100%;
    max-width: 480px;
    border-radius: 60px; 
    padding: 40px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.05);
    min-height: 550px;
    position: relative;
    z-index: 2;
  }

  .vicca-placeholder {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 400px;
    text-align: center;
    border: 2px dashed #ccc;
    border-radius: 40px;
    padding: 20px;
  }

  @media (max-width: 1024px) {
    .vicca-h2 { font-size: 48px; }
    .vicca-tagline-bold { font-size: 42px; }
  }

  @media (max-width: 768px) {
    .vicca-flex-layout { flex-direction: column; }
    .vicca-top-bg { clip-path: none; padding: 60px 0; margin-bottom: 0; }
    .vicca-h2 { font-size: 36px; }
    .vicca-card { border-radius: 40px; padding: 20px; width: auto; min-height: auto; }
    .vicca-tagline { font-size: 28px; }
    .vicca-tagline-bold { font-size: 36px; }
  }
</style>