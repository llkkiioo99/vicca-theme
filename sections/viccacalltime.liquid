{% schema %}
{
  "name": "Vicca Booking Section",
  "settings": [
    {
      "type": "text",
      "id": "top_tagline",
      "label": "Top Tagline",
      "default": "Step Into"
    },
    {
      "type": "text",
      "id": "top_tagline_bold",
      "label": "Top Tagline Bold",
      "default": "Opportunity"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "¿Listo/a para dar el primer paso?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Agenda una llamada con el equipo de vicca"
    },
    {
      "type": "textarea",
      "id": "description_1",
      "label": "Description Paragraph 1",
      "default": "Conocerás en qué consiste el programa, cómo podemos ayudarte paso a paso y si realmente se adapta a lo que necesitas."
    },
    {
      "type": "textarea",
      "id": "description_2",
      "label": "Description Paragraph 2",
      "default": "Queremos que tomes decisiones con claridad, esta es tu oportunidad. Resuelve tus dudas y descubre si este programa es para ti."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfaf5"
    },
    {
      "type": "text",
      "id": "cal_embed_url",
      "label": "Cal.com Booking URL",
      "default": "vicca-agency/discovery-call",
      "info": "Your Cal.com username/event-slug (e.g. vicca-agency/discovery-call)"
    },
    {
      "type": "text",
      "id": "typeform_id",
      "label": "Typeform Form ID",
      "info": "Your Typeform form ID for pre-call info (e.g. abc123XY). Leave empty to hide."
    }
  ],
  "presets": [
    {
      "name": "Vicca Booking Section"
    }
  ]
}
{% endschema %}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<section class="vicca-booking-wrapper">
  <div class="vicca-top-bg">
     <div class="vicca-container">
        <div class="vicca-tagline-area">
          <p class="vicca-tagline">{{ section.settings.top_tagline }}</p>
          <h1 class="vicca-tagline-bold">{{ section.settings.top_tagline_bold }}</h1>
        </div>
     </div>
  </div>

  <div class="vicca-main-section" style="background-color: {{ section.settings.bg_color }};">
    <div class="vicca-container">
      <div class="vicca-flex-layout">

        <div class="vicca-content">
          <h2 class="vicca-h2">{{ section.settings.heading }}</h2>
          <h3 class="vicca-h3">{{ section.settings.subheading }}<span class="dot">.</span></h3>

          <div class="vicca-desc">
            <p>{{ section.settings.description_1 }}</p>
            <p>{{ section.settings.description_2 }}</p>
          </div>

          <ul class="vicca-list">
            <li><span class="check-icon">&#10003;</span> Acompañamiento personalizado.</li>
            <li><span class="check-icon">&#10003;</span> Decide con claridad.</li>
            <li><span class="check-icon">&#10003;</span> Reunión vía Google Meet sin compromiso.</li>
          </ul>

          {%- if section.settings.typeform_id != blank -%}
            <div class="vicca-typeform-wrapper">
              <p class="vicca-typeform-label">Completa el formulario antes de tu llamada:</p>
              <div data-tf-live="{{ section.settings.typeform_id }}" data-tf-opacity="100" style="width:100%;height:400px;"></div>
            </div>
          {%- endif -%}
        </div>

        <div class="vicca-calendar-wrapper">
          <div class="vicca-card">
            <div class="vicca-cal-tabs">
              <button class="vicca-cal-tab active" data-tab="morning" onclick="viccaSwitchTab(this, 'morning')">Mañana (09–14h)</button>
              <button class="vicca-cal-tab" data-tab="afternoon" onclick="viccaSwitchTab(this, 'afternoon')">Tarde (15–17:15h)</button>
            </div>
            <div class="vicca-cal-embed" id="vicca-cal-container">
              <!-- Cal.com inline embed -->
              <div id="vicca-cal-inline" style="width:100%;height:100%;overflow:auto;"></div>
            </div>
            <p class="vicca-cal-note">Duración máxima: 45 minutos</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Cal.com embed script -->
<script>
(function() {
  var calUrl = "{{ section.settings.cal_embed_url | escape }}";
  if (!calUrl) return;

  // Load Cal.com embed script
  (function (C, A, L) {
    var p = function (a, ar) { a.q.push(ar); };
    var d = C.document;
    C.Cal = C.Cal || function () {
      var cal = C.Cal;
      var ar = arguments;
      if (!cal.loaded) {
        cal.ns = {};
        cal.q = cal.q || [];
        d.head.appendChild(d.createElement("script")).src = A;
        cal.loaded = true;
      }
      if (ar[0] === L) {
        var api = function () { p(api, arguments); };
        var namespace = ar[1];
        api.q = api.q || [];
        if (typeof namespace === "string") { cal.ns[namespace] = cal.ns[namespace] || api; p(cal.ns[namespace], ar); p(cal, ["initNamespace", namespace]); } else p(cal, ar);
        return;
      }
      p(cal, ar);
    };
  })(window, "https://app.cal.com/embed/embed.js", "init");

  Cal("init", "vicca-booking", { origin: "https://app.cal.com" });
  Cal.ns["vicca-booking"]("inline", {
    elementOrSelector: "#vicca-cal-inline",
    calLink: calUrl,
    layout: "month_view",
    config: {
      theme: "light"
    }
  });
  Cal.ns["vicca-booking"]("ui", {
    theme: "light",
    styles: { branding: { brandColor: "#ff914d" } },
    hideEventTypeDetails: false,
    layout: "month_view"
  });
})();

function viccaSwitchTab(el, tab) {
  document.querySelectorAll('.vicca-cal-tab').forEach(function(t) { t.classList.remove('active'); });
  el.classList.add('active');
}
</script>

{%- if section.settings.typeform_id != blank -%}
  <script src="//embed.typeform.com/next/embed.js"></script>
{%- endif -%}

<style>
  .vicca-booking-wrapper {
    position: relative;
    overflow: hidden;
    font-family: 'Poppins', sans-serif;
  }

  .vicca-top-bg {
    background: #ffffff;
    padding: 80px 0 120px 0;
    margin-bottom: -80px;
    clip-path: polygon(0 0, 100% 0, 100% 70%, 0 100%);
  }

  .vicca-main-section {
    padding: 80px 0 100px 0;
  }

  .vicca-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .vicca-flex-layout {
    display: flex;
    align-items: flex-start;
    gap: 60px;
  }

  .vicca-tagline-area { margin-bottom: 20px; }

  .vicca-tagline {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 400;
    margin: 0;
    line-height: 1.2;
    color: #000;
  }

  .vicca-tagline-bold {
    font-family: 'Poppins', sans-serif;
    font-size: 48px;
    font-weight: 800;
    margin: 0;
    line-height: 1;
    color: #000;
  }

  .vicca-content { flex: 1.2; }
  .vicca-calendar-wrapper { flex: 1; }

  .vicca-h2 {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 24px;
    color: #000;
    letter-spacing: -1px;
  }

  .vicca-h3 {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(18px, 2vw, 24px);
    font-weight: 700;
    margin-bottom: 20px;
    color: #000;
  }

  .dot { color: #f28132; }

  .vicca-desc p {
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    color: #555;
    line-height: 1.6;
    margin-bottom: 16px;
    max-width: 520px;
  }

  .vicca-list { list-style: none; padding: 0; margin-top: 32px; }
  .vicca-list li {
    display: flex;
    align-items: center;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    margin-bottom: 12px;
    font-size: 16px;
    color: #000;
  }

  .check-icon {
    background: #f28132;
    color: white;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-right: 12px;
    font-size: 11px;
    flex-shrink: 0;
  }

  .vicca-card {
    background: #ffffff;
    width: 100%;
    max-width: 480px;
    border-radius: 40px;
    padding: 30px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.06);
    min-height: 500px;
    position: relative;
    z-index: 2;
  }

  .vicca-cal-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }

  .vicca-cal-tab {
    flex: 1;
    padding: 10px 16px;
    border: 2px solid #eee;
    background: #fff;
    border-radius: 50px;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #666;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .vicca-cal-tab.active {
    background: #f28132;
    color: #fff;
    border-color: #f28132;
  }

  .vicca-cal-embed {
    min-height: 400px;
    border-radius: 20px;
    overflow: hidden;
  }

  .vicca-cal-note {
    text-align: center;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    color: #999;
    margin-top: 12px;
    font-weight: 500;
  }

  .vicca-typeform-wrapper {
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid #eee;
  }

  .vicca-typeform-label {
    font-family: 'Poppins', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #000;
    margin-bottom: 16px;
  }

  .vicca-placeholder {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 400px;
    text-align: center;
    border: 2px dashed #ccc;
    border-radius: 30px;
    padding: 20px;
  }

  @media (max-width: 1024px) {
    .vicca-tagline-bold { font-size: 40px; }
  }

  @media (max-width: 768px) {
    .vicca-flex-layout { flex-direction: column; gap: 40px; }
    .vicca-top-bg { clip-path: none; padding: 50px 0; margin-bottom: 0; }
    .vicca-main-section { padding: 50px 0 60px 0; }
    .vicca-card { border-radius: 30px; padding: 20px; width: 100%; max-width: 100%; min-height: auto; }
    .vicca-tagline { font-size: 24px; }
    .vicca-tagline-bold { font-size: 32px; }
    .vicca-cal-tabs { flex-direction: column; }
    .vicca-cal-tab { text-align: center; }
  }
</style>