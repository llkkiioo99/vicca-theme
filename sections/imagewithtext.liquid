{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap');

  /* Desktop Settings (Default) */
  .custom-text-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    width: 100%;
    overflow: hidden;
  }

  .custom-text-container-{{ section.id }} {
    width: 100%;
    max-width: {{ section.settings.content_width }}px;
    padding: 0 20px;
    margin: 0 auto;
  }

  .custom-text-section-{{ section.id }} .rte p {
    font-family: 'Poppins', sans-serif;
    font-size: {{ section.settings.font_size }}px;
    line-height: 1.3;
    color: {{ section.settings.text_color }};
    margin: 0;
    word-wrap: break-word;
  }

  .custom-text-section-{{ section.id }} strong {
    font-weight: 700;
  }

  /* Laptop/Tablet (Up to 1024px) */
  @media screen and (max-width: 1024px) {
    .custom-text-section-{{ section.id }} .rte p {
      font-size: calc({{ section.settings.font_size }}px * 0.9);
    }
  }

  /* Mobile Settings (Up to 749px) */
  @media screen and (max-width: 749px) {
    .custom-text-section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
    .custom-text-section-{{ section.id }} .rte p {
      font-size: {{ section.settings.font_size_mobile }}px;
      line-height: 1.2;
    }
  }
{%- endstyle -%}

<div class="custom-text-section-{{ section.id }}">
  <div class="custom-text-container-{{ section.id }}">
    <div class="rte">
      {{ section.settings.text_content }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Responsive Custom Text",
  "settings": [
    {
      "type": "richtext",
      "id": "text_content",
      "label": "Text Content",
      "default": "<p>Esta guía no es simple teoría:<br>está <strong>construida desde la experiencia real.</strong></p>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f7f0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 400,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Max Content Width",
      "default": 900
    },
    {
      "type": "header",
      "content": "Typography Settings"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 16,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Desktop Font Size",
      "default": 32
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 12,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Mobile Font Size",
      "default": 22
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "Desktop Padding Top",
      "default": 150
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "Desktop Padding Bottom",
      "default": 150
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Mobile Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Mobile Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Responsive Custom Text"
    }
  ]
}
{% endschema %}