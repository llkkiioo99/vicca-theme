{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap');

  .vbot-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    font-family: 'Poppins', sans-serif;
  }

  .vbot-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .vbot-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 800;
    color: #000;
    text-align: center;
    margin: 0 0 48px;
    letter-spacing: -0.5px;
  }

  .vbot-dot {
    color: {{ section.settings.dot_color }};
    font-weight: 900;
  }

  .vbot-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .vbot-card {
    background: #fff;
    border-radius: 24px;
    padding: 32px 28px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .vbot-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #ff914d;
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .vbot-card p {
    font-size: 15px;
    line-height: 1.5;
    color: #333;
    margin: 0;
    padding-top: 8px;
  }

  @media (max-width: 768px) {
    .vbot-grid { grid-template-columns: 1fr; }
    .vbot-card { padding: 28px 24px; border-radius: 20px; }
    .vbot-title { margin-bottom: 36px; }
  }

  @media (max-width: 480px) {
    .vbot-card { padding: 24px 20px; border-radius: 18px; }
    .vbot-card p { font-size: 14px; }
    .vbot-title { font-size: 22px; }
    .vbot-container { padding: 0 16px; }
  }
{%- endstyle -%}

<div class="vbot-section-{{ section.id }}">
  <div class="vbot-container">
    <h2 class="vbot-title">
      {{ section.settings.title_part1 }}<span class="vbot-dot">.</span>{{ section.settings.title_part2 }}
    </h2>

    <div class="vbot-grid">
      {%- if section.settings.text_1 != blank -%}
        <div class="vbot-card">
          <span class="vbot-icon">&#10003;</span>
          <p>{{ section.settings.text_1 }}</p>
        </div>
      {%- endif -%}
      {%- if section.settings.text_2 != blank -%}
        <div class="vbot-card">
          <span class="vbot-icon">&#10003;</span>
          <p>{{ section.settings.text_2 }}</p>
        </div>
      {%- endif -%}
      {%- if section.settings.text_3 != blank -%}
        <div class="vbot-card">
          <span class="vbot-icon">&#10003;</span>
          <p>{{ section.settings.text_3 }}</p>
        </div>
      {%- endif -%}
      {%- if section.settings.text_4 != blank -%}
        <div class="vbot-card">
          <span class="vbot-icon">&#10003;</span>
          <p>{{ section.settings.text_4 }}</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Vicca Affiliate Section",
  "settings": [
    {
      "type": "text",
      "id": "title_part1",
      "label": "Title before dot",
      "default": "¿Qué te llevas como vicca"
    },
    {
      "type": "text",
      "id": "title_part2",
      "label": "Title after dot",
      "default": "afiliate?"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot Color",
      "default": "#FF8C00"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9F7F2"
    },
    {
      "type": "header",
      "content": "List Content"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Line 1",
      "default": "Comisiones por cada persona que contrate Step Into Opportunity gracias a tu recomendación"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Line 2",
      "default": "Un sistema claro y sin letra pequeña"
    },
    {
      "type": "textarea",
      "id": "text_3",
      "label": "Line 3",
      "default": "Comunicación directa con el equipo vicca."
    },
    {
      "type": "textarea",
      "id": "text_4",
      "label": "Line 4",
      "default": "Formar parte de un proyecto en crecimiento, con valores claros"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Vicca Affiliate Section"
    }
  ]
}
{% endschema %}
