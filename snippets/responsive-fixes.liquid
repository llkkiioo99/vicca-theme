{% comment %}
  Global responsive fixes & layout normalization
  Ensures consistent sizing across all breakpoints
{% endcomment %}

<style>
  /* ============================
     Global box-sizing & overflow
     ============================ */
  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    overflow-x: hidden;
  }

  body {
    overflow-x: hidden;
    -webkit-text-size-adjust: 100%;
  }

  img, video, svg {
    max-width: 100%;
    height: auto;
  }

  /* ============================
     Global typography normalization
     Prevents oversized text at 100% zoom on 1440px
     ============================ */
  section, .shopify-section {
    max-width: 100vw;
    overflow-x: hidden;
  }

  /* ============================
     Tablet (768px – 1024px)
     ============================ */
  @media screen and (max-width: 1024px) {
    /* Reduce excessive paddings globally */
    .vicca-booking-wrapper,
    .vicca-banner-wrapper,
    .vicca-banner-section {
      padding-left: 4%;
      padding-right: 4%;
    }
  }

  /* ============================
     Mobile (375px – 768px)
     ============================ */
  @media screen and (max-width: 768px) {
    /* Prevent any horizontal overflow */
    main, #MainContent {
      overflow-x: hidden;
    }

    /* Normalize large font declarations that may not have mobile overrides */
    h1, .h1 { font-size: clamp(28px, 7vw, 48px) !important; }

    /* Ensure full-width blocks don't overflow */
    [class*="container"],
    [class*="wrapper"] {
      max-width: 100%;
    }

    /* Fix buttons on mobile */
    .hero-btn,
    .step-button,
    .vicca-button,
    .vicca-btn,
    .btn-orange,
    .btn-black {
      font-size: 15px;
    }
  }

  /* ============================
     Small mobile (375px – 430px)
     ============================ */
  @media screen and (max-width: 480px) {
    /* Tighter padding on small screens */
    .vicca-booking-wrapper,
    .vicca-banner-wrapper,
    .vicca-banner-section {
      padding-left: 16px;
      padding-right: 16px;
    }
  }
</style>