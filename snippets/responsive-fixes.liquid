{% comment %}
  Global responsive fixes & layout normalization
  Ensures consistent sizing across all breakpoints
{% endcomment %}

<style>
  /* ============================
     Global box-sizing & overflow
     ============================ */
  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    overflow-x: hidden;
    -webkit-text-size-adjust: 100%;
    scroll-behavior: smooth;
  }

  body {
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  img, video, svg {
    max-width: 100%;
    height: auto;
  }

  /* ============================
     Allow header dropdowns to overflow
     ============================ */
  .shopify-section-group-header-group,
  .shopify-section-group-header-group .shopify-section {
    overflow: visible !important;
  }

  /* ============================
     Section overflow control
     ============================ */
  section, .shopify-section {
    max-width: 100vw;
  }

  /* ============================
     Desktop normalization (1440px)
     Cap oversized elements
     ============================ */
  @media screen and (min-width: 1440px) {
    .serif-text { font-size: 48px !important; }
    .bold-text { font-size: 52px !important; }
    .bg-text-italic { font-size: 100px !important; }
  }

  /* ============================
     Tablet (768px – 1024px)
     ============================ */
  @media screen and (max-width: 1024px) {
    .vicca-booking-wrapper,
    .vicca-banner-wrapper,
    .vicca-banner-section {
      padding-left: 4%;
      padding-right: 4%;
    }
  }

  /* ============================
     Mobile (375px – 768px)
     ============================ */
  @media screen and (max-width: 768px) {
    main, #MainContent {
      overflow-x: hidden;
    }

    [class*="container"],
    [class*="wrapper"] {
      max-width: 100%;
    }

    /* Normalize buttons on mobile */
    .hero-btn,
    .step-button,
    .vicca-button,
    .vicca-btn,
    .btn-orange,
    .btn-black,
    .guide-button,
    .step-opportunity__btn,
    .aff-btn-submit {
      font-size: 15px;
    }
  }

  /* ============================
     Small mobile (375px – 430px)
     ============================ */
  @media screen and (max-width: 480px) {
    .vicca-booking-wrapper,
    .vicca-banner-wrapper,
    .vicca-banner-section {
      padding-left: 16px;
      padding-right: 16px;
    }

    /* Prevent text from being too small */
    p, li, span {
      word-break: break-word;
    }
  }
</style>