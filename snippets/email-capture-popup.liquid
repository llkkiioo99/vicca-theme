{% comment %}
  Email Capture Pop-up — "Envíame la guía gratis"
  Triggers after 1.1 seconds for first-time visitors
  Stores dismissal in localStorage for 7 days
  Submits to Shopify contact form + tags for Klaviyo segmentation
  Rate limiting: honeypot + time trap (1.5s) + 30s cooldown + 20/day cap
{% endcomment %}

<div id="vicca-email-popup" class="vicca-popup-overlay" aria-hidden="true">
  <div class="vicca-popup-card">
    <button class="vicca-popup-close" onclick="viccaClosePopup()" aria-label="Cerrar">&times;</button>
    <div class="vicca-popup-content">
      <p class="vicca-popup-pretitle">vicca<span class="vicca-popup-dot">.</span>agency</p>
      <h3 class="vicca-popup-heading">Descarga tu guía gratis</h3>
      <p class="vicca-popup-text">Déjanos tu correo y recibe al instante nuestra guía con todo lo que necesitas saber para dar el paso a los Países Bajos.</p>
      <form id="vicca-email-form" class="vicca-popup-form" onsubmit="return viccaSubmitEmail(event)">
        <input
          type="email"
          name="email"
          id="vicca-popup-email"
          class="vicca-popup-input"
          placeholder="Tu email"
          required
          autocomplete="email"
        >
        <input
          type="text"
          name="website"
          id="vicca-popup-hp"
          class="vicca-popup-hp"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        >
        <button type="submit" class="vicca-popup-btn">Envíame la guía gratis</button>
      </form>
      <p class="vicca-popup-note">Sin spam. Solo contenido útil.</p>
      <p id="vicca-popup-success" class="vicca-popup-success" style="display:none;">
        ¡Listo! Revisa tu bandeja de entrada 📩
      </p>
    </div>
  </div>
</div>

<style>
  .vicca-popup-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease, visibility 0.35s ease;
    padding: 20px;
  }

  .vicca-popup-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .vicca-popup-card {
    background: #fff;
    border-radius: 24px;
    padding: 48px 40px 40px;
    max-width: 440px;
    width: 100%;
    position: relative;
    transform: translateY(30px) scale(0.96);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
  }

  .vicca-popup-overlay.active .vicca-popup-card {
    transform: translateY(0) scale(1);
  }

  .vicca-popup-close {
    position: absolute;
    top: 16px;
    right: 20px;
    background: none;
    border: none;
    font-size: 28px;
    color: #999;
    cursor: pointer;
    line-height: 1;
    padding: 4px;
    transition: color 0.2s;
  }

  .vicca-popup-close:hover { color: #000; }

  .vicca-popup-content { text-align: center; }

  .vicca-popup-pretitle {
    font-family: 'Poppins', sans-serif;
    font-size: 18px;
    font-weight: 800;
    color: #000;
    margin: 0 0 8px;
  }

  .vicca-popup-dot { color: #ff914d; }

  .vicca-popup-heading {
    font-family: 'Poppins', sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: #000;
    margin: 0 0 10px;
    line-height: 1.2;
  }

  .vicca-popup-text {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #666;
    line-height: 1.5;
    margin: 0 0 24px;
  }

  .vicca-popup-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .vicca-popup-input {
    width: 100%;
    padding: 14px 18px;
    border: 2px solid #eee;
    border-radius: 50px;
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    color: #000;
    outline: none;
    transition: border-color 0.2s;
    background: #fafafa;
    box-sizing: border-box;
  }

  .vicca-popup-input:focus { border-color: #ff914d; }

  .vicca-popup-hp {
    position: absolute !important;
    left: -9999px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0 !important;
    pointer-events: none !important;
    top: auto !important;
  }

  .vicca-popup-btn {
    width: 100%;
    padding: 14px 28px;
    background: #ff914d;
    color: #fff;
    border: none;
    border-radius: 50px;
    font-family: 'Poppins', sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .vicca-popup-btn:hover { background: #e8803a; }

  .vicca-popup-note {
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    color: #999;
    margin-top: 12px;
  }

  .vicca-popup-success {
    font-family: 'Poppins', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #2ecc71;
    margin-top: 16px;
  }

  @media (max-width: 480px) {
    .vicca-popup-card { padding: 36px 24px 30px; border-radius: 20px; }
    .vicca-popup-heading { font-size: 22px; }
    .vicca-popup-btn { font-size: 14px; padding: 13px 20px; }
  }
</style>

<script>
window._viccaPopupShownAt = 0;

(function() {
  var popup = document.getElementById('vicca-email-popup');
  if (!popup) return;

  // Only show on homepage
  var path = window.location.pathname;
  var isHome = (path === '/' || path === '' || path.indexOf('/preview_theme_id') === 0);
  if (!isHome) return;

  var reopenTimer = null;

  function showPopup() {
    popup.classList.add('active');
    popup.setAttribute('aria-hidden', 'false');
    window._viccaPopupShownAt = Date.now();
  }

  // Show after 1.1 seconds on homepage
  setTimeout(showPopup, 1100);

  // Close on backdrop click
  popup.addEventListener('click', function(e) {
    if (e.target === popup) viccaClosePopup();
  });

  // Close on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && popup.classList.contains('active')) viccaClosePopup();
  });

  window._viccaPopupReopen = function() {
    // Re-show after 2 minutes if still on homepage
    if (reopenTimer) clearTimeout(reopenTimer);
    reopenTimer = setTimeout(function() {
      if (window.location.pathname === '/' || window.location.pathname === '') {
        showPopup();
      }
    }, 120000);
  };
})();

function viccaClosePopup() {
  var popup = document.getElementById('vicca-email-popup');
  popup.classList.remove('active');
  popup.setAttribute('aria-hidden', 'true');
  // Schedule reappearance in 2 minutes
  if (typeof window._viccaPopupReopen === 'function') {
    window._viccaPopupReopen();
  }
}

function viccaSubmitEmail(e) {
  e.preventDefault();
  var email = document.getElementById('vicca-popup-email').value;
  if (!email) return false;

  var btn = document.querySelector('.vicca-popup-btn');

  // Honeypot: bots fill hidden field, humans don't see it
  var hp = document.getElementById('vicca-popup-hp');
  if (hp && hp.value) {
    // Silent fake success so bots don't retry
    document.getElementById('vicca-email-form').style.display = 'none';
    document.querySelector('.vicca-popup-note').style.display = 'none';
    document.getElementById('vicca-popup-success').style.display = 'block';
    return false;
  }

  var now = Date.now();

  // Time trap: block submits faster than 1.5s after popup open (bot signature)
  var shownAt = window._viccaPopupShownAt || 0;
  if (shownAt === 0 || (now - shownAt) < 1500) {
    btn.textContent = 'Un momento...';
    setTimeout(function() { btn.textContent = 'Envíame la guía gratis'; }, 1500);
    return false;
  }

  // Cooldown: 30s between submits from same browser
  var lastSubmit = parseInt(localStorage.getItem('vicca_popup_last_submit') || '0', 10);
  if (now - lastSubmit < 30000) {
    var wait = Math.ceil((30000 - (now - lastSubmit)) / 1000);
    btn.textContent = 'Espera ' + wait + 's';
    setTimeout(function() { btn.textContent = 'Envíame la guía gratis'; }, 2000);
    return false;
  }

  // Daily cap: 20 submits per browser per day
  var dayKey = 'vicca_popup_count_' + new Date().toISOString().slice(0, 10);
  var dayCount = parseInt(localStorage.getItem(dayKey) || '0', 10);
  if (dayCount >= 20) {
    btn.textContent = 'Límite diario alcanzado';
    btn.disabled = true;
    return false;
  }

  // Passed all checks, record submit
  localStorage.setItem('vicca_popup_last_submit', now.toString());
  localStorage.setItem(dayKey, (dayCount + 1).toString());

  btn.disabled = true;
  btn.textContent = 'Enviando...';

  var KLAVIYO_COMPANY_ID = 'VrALBU';
  var KLAVIYO_LIST_ID = 'RFUakM';

  var klaviyoPayload = {
    data: {
      type: 'subscription',
      attributes: {
        custom_source: 'Newsletter popup — Free guide',
        profile: {
          data: {
            type: 'profile',
            attributes: {
              email: email,
              properties: { source: 'free_guide_popup' }
            }
          }
        }
      },
      relationships: {
        list: { data: { type: 'list', id: KLAVIYO_LIST_ID } }
      }
    }
  };

  var klaviyoReq = fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_COMPANY_ID, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'revision': '2024-10-15'
    },
    body: JSON.stringify(klaviyoPayload)
  });

  var shopifyReq = fetch(window.Shopify && window.Shopify.routes ? window.Shopify.routes.root + 'contact' : '/contact', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'form_type=customer&utf8=%E2%9C%93&contact%5Bemail%5D=' + encodeURIComponent(email) + '&contact%5Btags%5D=newsletter_popup,free_guide'
  });

  var showSuccess = function() {
    document.getElementById('vicca-email-form').style.display = 'none';
    document.querySelector('.vicca-popup-note').style.display = 'none';
    document.getElementById('vicca-popup-success').style.display = 'block';
    setTimeout(viccaClosePopup, 3000);
  };

  Promise.allSettled([klaviyoReq, shopifyReq]).then(showSuccess).catch(showSuccess);

  return false;
}
</script>
